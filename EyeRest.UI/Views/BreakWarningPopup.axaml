<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EyeRest.UI.Views.BreakWarningPopup">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <!-- Single card: mesh gradient clipped to rounded border -->
        <Border Background="{DynamicResource MeshGradientBrush}"
                CornerRadius="20"
                ClipToBounds="True"
                Padding="0">
            <!-- Glass overlay -->
            <Border Background="{DynamicResource GlassCardBackground}"
                    BorderBrush="{DynamicResource GlassCardBorder}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="28,24">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" Spacing="12">
                        <!-- Icon Circle -->
                        <Border Width="56" Height="56"
                                CornerRadius="28"
                                Background="{DynamicResource BreakIconCircle}"
                                HorizontalAlignment="Center">
                            <PathIcon Data="{DynamicResource ClockIcon}"
                                      Width="28" Height="28"
                                      Foreground="{DynamicResource WarningBrush}" />
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="Break Starting Soon"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />

                        <!-- Countdown -->
                        <TextBlock Name="CountdownText"
                                   Text="30 seconds"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"
                                   HorizontalAlignment="Center" />

                        <!-- Progress Bar -->
                        <ProgressBar Name="ProgressBar"
                                     Width="200"
                                     Height="6"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="100"
                                     IsIndeterminate="False"
                                     Foreground="{DynamicResource WarningBrush}"
                                     Background="{DynamicResource GlassPanelBackground}"
                                     HorizontalAlignment="Center" />

                        <!-- Hint -->
                        <TextBlock Text="Press ESC to dismiss"
                                   FontSize="11"
                                   Foreground="{DynamicResource ContentSubtitleText}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Close Button -->
                    <Button Name="CloseButton"
                            Classes="PopupCloseBtn"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-4,-4,0"
                            ToolTip.Tip="Dismiss (ESC)">
                        <PathIcon Data="{DynamicResource CloseIcon}"
                                  Width="12" Height="12" />
                    </Button>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
