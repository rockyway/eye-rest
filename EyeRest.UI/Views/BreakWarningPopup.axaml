<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EyeRest.UI.Views.BreakWarningPopup">
    <Grid>
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource WarningBrush}"
                BorderThickness="2"
                CornerRadius="15"
                MaxWidth="400"
                BoxShadow="4 4 16 0 #66808080">

            <!-- Inner Grid to allow close button overlay -->
            <Grid>
                <!-- Main content with padding -->
                <StackPanel Margin="30,30,30,20">
                    <!-- Warning Icon -->
                    <TextBlock Text="&#x23F0;"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <!-- Warning Message -->
                    <TextBlock Text="Break Starting Soon"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- Countdown -->
                    <TextBlock Name="CountdownText"
                               Text="30 seconds"
                               FontSize="16"
                               Foreground="{DynamicResource WarningBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <!-- Vertical Progress Bar (starts at 100, falls to 0) -->
                    <ProgressBar Name="ProgressBar"
                                 Width="8"
                                 Height="100"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="100"
                                 IsIndeterminate="False"
                                 Foreground="{DynamicResource WarningBrush}"
                                 Background="{DynamicResource TextSecondaryBrush}"
                                 Orientation="Vertical"
                                 HorizontalAlignment="Center"/>

                    <!-- Skip hint -->
                    <TextBlock Text="Press ESC to dismiss"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Close button inside popup, top right corner -->
                <Button Name="CloseButton"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Background="Transparent"
                        Cursor="Hand"
                        ToolTip.Tip="Dismiss (ESC)">
                    <Button.Template>
                        <ControlTemplate>
                            <Border Background="Transparent"
                                    BorderBrush="{DynamicResource WarningBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock Text="&#x2715;"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource WarningBrush}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
