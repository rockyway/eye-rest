<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EyeRest.UI.Views.MainWindow"
        Title="Eye-rest"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
        <TextBlock Text="Eye-rest" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="Cross-platform eye rest reminder" HorizontalAlignment="Center" Opacity="0.7" />
        <TextBlock Text="Avalonia UI - Placeholder" HorizontalAlignment="Center" Opacity="0.5" Margin="0,20,0,0" />
    </StackPanel>
</Window>
