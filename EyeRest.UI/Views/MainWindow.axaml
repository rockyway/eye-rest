<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EyeRest.UI.ViewModels"
        xmlns:converters="using:EyeRest.UI.Converters"
        xmlns:local="using:EyeRest.UI.Views"
        x:Class="EyeRest.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Width="340" Height="580"
        MinWidth="340" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="40"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <converters:EqualityConverter x:Key="EqualityConverter" />
        <converters:BoolToTextConverter x:Key="BoolToTextConverter" />
        <converters:PercentToScaleConverter x:Key="PercentToScaleConverter" />
    </Window.Resources>

    <!-- Outer border with mesh gradient background and rounded corners -->
    <!-- CornerRadius=10 matches macOS native window corner radius to avoid gaps -->
    <Border Background="{DynamicResource MeshGradientBrush}"
            CornerRadius="10"
            ClipToBounds="True">

        <Grid RowDefinitions="40,*">

            <!-- ============================================================ -->
            <!-- Row 0: Custom Title Bar                                       -->
            <!-- ============================================================ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBackground}"
                    PointerPressed="TitleBar_PointerPressed">
                <Grid>
                    <!-- Left: Hamburger menu (Windows only) -->
                    <Button Classes="CaptionBtn"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="0,-1,0,0"
                            Height="40"
                            ToolTip.Tip="Menu"
                            IsVisible="{OnPlatform False, Windows=True}">
                        <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                <MenuItem Header="About Eye-Rest" Click="AboutMenuItem_Click" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Centered: App icon + title -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Image Source="avares://EyeRest/Assets/TrayIcons/tray_active.png"
                               Width="18" Height="18" />
                        <TextBlock Text="Eye Rest"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Right: Window control buttons (Windows only) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-1,0,0"
                                IsVisible="{OnPlatform False, Windows=True}">
                        <Button Classes="CaptionBtn" Click="MinimizeButton_Click"
                                ToolTip.Tip="Minimize" Height="40">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button Classes="CaptionBtn CaptionCloseBtn" Click="CloseButton_Click"
                                ToolTip.Tip="Close" Height="40">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================================ -->
            <!-- Row 1: Main Content                                           -->
            <!-- ============================================================ -->
            <Panel Grid.Row="1">

                <!-- ======================================================== -->
                <!-- SIMPLE MODE (default)                                     -->
                <!-- ======================================================== -->
                <Border IsVisible="{Binding IsNotConfigurationMode}"
                        Background="{DynamicResource SidebarBackground}">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">

                        <!-- Settings gear button to switch to config mode -->
                        <StackPanel Grid.Row="0" Margin="12,10,12,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6"
                                    Cursor="Hand"
                                    ToolTip.Tip="Open Configuration"
                                    Command="{Binding ToggleConfigurationModeCommand}">
                                <PathIcon Data="{StaticResource SettingsIcon}"
                                          Width="18" Height="18"
                                          Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Button>
                        </StackPanel>

                        <!-- Status Card - Dual timer cards with progress -->
                        <Border Grid.Row="1" Margin="12,6,12,0">
                            <StackPanel Spacing="10">

                                <!-- Status pill badge -->
                                <Border Classes="StatusPillBadge"
                                        HorizontalAlignment="Left"
                                        Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{Binding TimerStatusColor}"
                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding TimerStatusText}"
                                                   Classes="StatusPillText" />
                                    </StackPanel>
                                </Border>

                                <!-- Two timer cards side by side -->
                                <Grid ColumnDefinitions="*,8,*">

                                    <!-- Eye Rest Timer Card (clickable → navigates to Eye Rest config tab) -->
                                    <Button Grid.Column="0"
                                            Command="{Binding NavigateToConfigurationTabCommand}"
                                            CommandParameter="0"
                                            Background="Transparent" BorderThickness="0" Padding="0"
                                            Cursor="Hand"
                                            HorizontalAlignment="Stretch"
                                            ToolTip.Tip="{Binding EyeRestTimerTooltip}">
                                        <Border Classes="TimerMiniCard">
                                            <StackPanel Spacing="7">
                                                <Border Classes="TimerIconCircle"
                                                        HorizontalAlignment="Center">
                                                    <PathIcon Data="{StaticResource EyeIcon}"
                                                              Width="14" Height="14"
                                                              Foreground="{DynamicResource ToggleCardIconColor}" />
                                                </Border>
                                                <TextBlock Text="{Binding EyeRestCountdownText}"
                                                           Classes="TimerCountdown"
                                                           HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Height="4" CornerRadius="2" Margin="4,2"
                                                        Background="{DynamicResource StatusCardBackground}"
                                                        ClipToBounds="True">
                                                    <Border Background="{DynamicResource PrimaryBrush}"
                                                            CornerRadius="2"
                                                            HorizontalAlignment="Stretch"
                                                            RenderTransformOrigin="0%,50%">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="{Binding EyeRestProgressPercent, Converter={StaticResource PercentToScaleConverter}}" />
                                                        </Border.RenderTransform>
                                                    </Border>
                                                </Border>
                                                <TextBlock Text="Eye Rest"
                                                           Classes="TimerLabel"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Button>

                                    <!-- Break Timer Card (clickable → navigates to Break config tab) -->
                                    <Button Grid.Column="2"
                                            Command="{Binding NavigateToConfigurationTabCommand}"
                                            CommandParameter="1"
                                            Background="Transparent" BorderThickness="0" Padding="0"
                                            Cursor="Hand"
                                            HorizontalAlignment="Stretch"
                                            ToolTip.Tip="{Binding BreakTimerTooltip}">
                                        <Border Classes="TimerMiniCard">
                                            <StackPanel Spacing="7">
                                                <Border Classes="TimerIconCircle"
                                                        HorizontalAlignment="Center">
                                                    <PathIcon Data="{StaticResource ClockIcon}"
                                                              Width="14" Height="14"
                                                              Foreground="{DynamicResource ToggleCardIconColor}" />
                                                </Border>
                                                <TextBlock Text="{Binding BreakCountdownText}"
                                                           Classes="TimerCountdown"
                                                           HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Height="4" CornerRadius="2" Margin="4,2"
                                                        Background="{DynamicResource StatusCardBackground}"
                                                        ClipToBounds="True">
                                                    <Border Background="{DynamicResource AccentBrush}"
                                                            CornerRadius="2"
                                                            HorizontalAlignment="Stretch"
                                                            RenderTransformOrigin="0%,50%">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="{Binding BreakProgressPercent, Converter={StaticResource PercentToScaleConverter}}" />
                                                        </Border.RenderTransform>
                                                    </Border>
                                                </Border>
                                                <TextBlock Text="Break"
                                                           Classes="TimerLabel"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Button>

                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Spacer + Donation Banner -->
                        <DockPanel Grid.Row="2">
                            <local:DonationBannerView DockPanel.Dock="Bottom" />
                            <Panel />
                        </DockPanel>

                        <!-- Bottom: Meeting + Controls + Exit -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,12" Spacing="4">

                            <!-- Meeting Buttons -->
                            <Grid ColumnDefinitions="*,*" Margin="12,4,12,4">
                                <Button Grid.Column="0" Classes="MeetingBtn"
                                        Command="{Binding PauseForMeetingCommand}"
                                        IsEnabled="{Binding CanPauseMeeting}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding Meeting30mButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" />
                                        <TextBlock Text="Meet 30m" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Classes="MeetingBtn"
                                        Command="{Binding PauseForMeeting1hCommand}"
                                        IsEnabled="{Binding CanPauseMeeting}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding Meeting1hButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" />
                                        <TextBlock Text="Meet 1h" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Start + Break Now row (each half width) -->
                            <Grid ColumnDefinitions="*,4,*" Margin="8,0">
                                <Button Grid.Column="0" Classes="GradientStart"
                                        Command="{Binding StartTimersCommand}"
                                        ToolTip.Tip="{Binding StartButtonTooltip}"
                                        Height="42" Margin="0">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource PlayIcon}" Width="14" Height="14" Foreground="White" />
                                        <TextBlock Text="Start" Foreground="White" FontSize="14" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Classes="GradientBreakNow"
                                        Command="{Binding TriggerImmediateBreakCommand}"
                                        IsEnabled="{Binding CanTriggerImmediateBreak}"
                                        ToolTip.Tip="Take a break now (uses configured break duration)"
                                        Height="42" Margin="0">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" Foreground="White" />
                                        <TextBlock Text="Break Now" Foreground="White" FontSize="14" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Stop + Pause row -->
                            <Grid ColumnDefinitions="*,*" Margin="4,0">
                                <Button Grid.Column="0" Classes="GradientStop"
                                        Command="{Binding StopTimersCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding StopButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource StopIcon}" Width="12" Height="12" Foreground="White" />
                                        <TextBlock Text="Stop" Foreground="White" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Classes="GradientPause"
                                        Command="{Binding PauseTimersCommand}"
                                        IsEnabled="{Binding CanPauseTimers}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding PauseButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource PauseIcon}" Width="12" Height="12" Foreground="White" />
                                        <TextBlock Text="Pause" Foreground="White" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Resume button (visible when paused) -->
                            <Button Classes="GradientStart"
                                    Command="{Binding ResumeTimersCommand}"
                                    IsEnabled="{Binding CanResumeTimers}"
                                    IsVisible="{Binding CanResumeTimers}"
                                    ToolTip.Tip="{Binding ResumeButtonTooltip}"
                                    Height="36" Margin="8,0">
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="{StaticResource PlayIcon}" Width="12" Height="12" Foreground="White" />
                                    <TextBlock Text="Resume" Foreground="White" FontSize="15" />
                                </StackPanel>
                            </Button>

                            <!-- Exit button -->
                            <Button Margin="8,4,8,0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Height="30"
                                    CornerRadius="8"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Command="{Binding ExitApplicationCommand}"
                                    ToolTip.Tip="Exit application"
                                    FontSize="12" Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="{StaticResource ExitIcon}" Width="14" Height="14"
                                              Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="Exit" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ======================================================== -->
                <!-- CONFIGURATION MODE                                        -->
                <!-- ======================================================== -->
                <Grid IsVisible="{Binding IsConfigurationMode}" ColumnDefinitions="260,*">

                <!-- ======================================================== -->
                <!-- Col 0: Sidebar                                            -->
                <!-- ======================================================== -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="{DynamicResource GlassPanelBorder}"
                        BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

                        <!-- Back to Simple Mode button -->
                        <StackPanel Grid.Row="0" Margin="8,10,8,0"
                                    Orientation="Horizontal">
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8,4"
                                    Cursor="Hand"
                                    ToolTip.Tip="Back to Simple View"
                                    Command="{Binding ToggleConfigurationModeCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource BackArrowIcon}"
                                              Width="16" Height="16"
                                              Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="Simple View"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Nav Buttons -->
                        <StackPanel Grid.Row="1" Margin="0,6,0,0">
                            <Button Classes="NavButton"
                                    Classes.active="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0}"
                                    Tag="0" Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource EyeIcon}" Width="18" Height="18" />
                                    <TextBlock Text="Eye Rest" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="NavButton"
                                    Classes.active="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}"
                                    Tag="1" Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource ClockIcon}" Width="18" Height="18" />
                                    <TextBlock Text="Time Break" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="NavButton"
                                    Classes.active="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2}"
                                    Tag="2" Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource TuneIcon}" Width="18" Height="18" />
                                    <TextBlock Text="Advanced" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="NavButton"
                                    Classes.active="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3}"
                                    Tag="3" Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource ChartIcon}" Width="18" Height="18" />
                                    <TextBlock Text="Analytics" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Status Card - Dual timer cards with progress -->
                        <Border Grid.Row="2" Margin="8,12,8,0">
                            <StackPanel Spacing="8">

                                <!-- Status pill badge -->
                                <Border Classes="StatusPillBadge"
                                        HorizontalAlignment="Left"
                                        Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{Binding TimerStatusColor}"
                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding TimerStatusText}"
                                                   Classes="StatusPillText" />
                                    </StackPanel>
                                </Border>

                                <!-- Two timer cards side by side -->
                                <Grid ColumnDefinitions="*,6,*">

                                    <!-- Eye Rest Timer Card -->
                                    <Border Grid.Column="0" Classes="TimerMiniCard"
                                            ToolTip.Tip="{Binding EyeRestTimerTooltip}">
                                        <StackPanel Spacing="6">
                                            <Border Classes="TimerIconCircle"
                                                    HorizontalAlignment="Center">
                                                <PathIcon Data="{StaticResource EyeIcon}"
                                                          Width="14" Height="14"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <TextBlock Text="{Binding EyeRestCountdownText}"
                                                       Classes="TimerCountdown"
                                                       HorizontalAlignment="Center"
                                                       FontSize="16"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Height="4" CornerRadius="2" Margin="4,2"
                                                    Background="{DynamicResource StatusCardBackground}"
                                                    ClipToBounds="True">
                                                <Border Background="{DynamicResource PrimaryBrush}"
                                                        CornerRadius="2"
                                                        HorizontalAlignment="Stretch"
                                                        RenderTransformOrigin="0%,50%">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="{Binding EyeRestProgressPercent, Converter={StaticResource PercentToScaleConverter}}" />
                                                    </Border.RenderTransform>
                                                </Border>
                                            </Border>
                                            <TextBlock Text="Eye Rest"
                                                       Classes="TimerLabel"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Break Timer Card -->
                                    <Border Grid.Column="2" Classes="TimerMiniCard"
                                            ToolTip.Tip="{Binding BreakTimerTooltip}">
                                        <StackPanel Spacing="6">
                                            <Border Classes="TimerIconCircle"
                                                    HorizontalAlignment="Center">
                                                <PathIcon Data="{StaticResource ClockIcon}"
                                                          Width="14" Height="14"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <TextBlock Text="{Binding BreakCountdownText}"
                                                       Classes="TimerCountdown"
                                                       HorizontalAlignment="Center"
                                                       FontSize="16"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Height="4" CornerRadius="2" Margin="4,2"
                                                    Background="{DynamicResource StatusCardBackground}"
                                                    ClipToBounds="True">
                                                <Border Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="2"
                                                        HorizontalAlignment="Stretch"
                                                        RenderTransformOrigin="0%,50%">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="{Binding BreakProgressPercent, Converter={StaticResource PercentToScaleConverter}}" />
                                                    </Border.RenderTransform>
                                                </Border>
                                            </Border>
                                            <TextBlock Text="Break"
                                                       Classes="TimerLabel"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Donation Banner -->
                        <local:DonationBannerView Grid.Row="3" VerticalAlignment="Bottom" />

                        <!-- Bottom: Meeting + Controls + Exit -->
                        <StackPanel Grid.Row="4" Margin="0,0,0,12" Spacing="4">

                            <!-- Meeting Buttons - styled as clear pill buttons -->
                            <Grid ColumnDefinitions="*,*" Margin="8,4,8,4">
                                <Button Grid.Column="0" Classes="MeetingBtn"
                                        Command="{Binding PauseForMeetingCommand}"
                                        IsEnabled="{Binding CanPauseMeeting}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding Meeting30mButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" />
                                        <TextBlock Text="Meet 30m" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Classes="MeetingBtn"
                                        Command="{Binding PauseForMeeting1hCommand}"
                                        IsEnabled="{Binding CanPauseMeeting}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding Meeting1hButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" />
                                        <TextBlock Text="Meet 1h" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Start + Break Now row (each half width) -->
                            <Grid ColumnDefinitions="*,4,*" Margin="4,0">
                                <Button Grid.Column="0" Classes="GradientStart"
                                        Command="{Binding StartTimersCommand}"
                                        ToolTip.Tip="{Binding StartButtonTooltip}"
                                        Margin="0">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource PlayIcon}" Width="14" Height="14" Foreground="White" />
                                        <TextBlock Text="Start" Foreground="White" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Classes="GradientBreakNow"
                                        Command="{Binding TriggerImmediateBreakCommand}"
                                        IsEnabled="{Binding CanTriggerImmediateBreak}"
                                        ToolTip.Tip="Take a break now (uses configured break duration)"
                                        Margin="0">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" Foreground="White" />
                                        <TextBlock Text="Break Now" Foreground="White" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Stop + Pause row -->
                            <Grid ColumnDefinitions="*,*" Margin="4,0">
                                <Button Grid.Column="0" Classes="GradientStop"
                                        Command="{Binding StopTimersCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding StopButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource StopIcon}" Width="12" Height="12" Foreground="White" />
                                        <TextBlock Text="Stop" Foreground="White" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Classes="GradientPause"
                                        Command="{Binding PauseTimersCommand}"
                                        IsEnabled="{Binding CanPauseTimers}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding PauseButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource PauseIcon}" Width="12" Height="12" Foreground="White" />
                                        <TextBlock Text="Pause" Foreground="White" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Resume button (visible when paused) -->
                            <Button Classes="GradientStart"
                                    Command="{Binding ResumeTimersCommand}"
                                    IsEnabled="{Binding CanResumeTimers}"
                                    IsVisible="{Binding CanResumeTimers}"
                                    ToolTip.Tip="{Binding ResumeButtonTooltip}"
                                    Height="36" Margin="8,0">
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="{StaticResource PlayIcon}" Width="12" Height="12" Foreground="White" />
                                    <TextBlock Text="Resume" Foreground="White" FontSize="15" />
                                </StackPanel>
                            </Button>

                            <!-- Exit button -->
                            <Button Margin="8,4,8,0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Height="30"
                                    CornerRadius="8"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Command="{Binding ExitApplicationCommand}"
                                    ToolTip.Tip="Exit application"
                                    FontSize="12" Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="{StaticResource ExitIcon}" Width="14" Height="14"
                                              Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="Exit" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ======================================================== -->
                <!-- Col 1: Content Area                                       -->
                <!-- ======================================================== -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*">

                    <!-- Fixed Title Section -->
                    <StackPanel Grid.Row="0" Margin="32,24,32,0">
                        <!-- Tab 0 title -->
                        <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0}">
                            <TextBlock Classes="SectionTitle" Text="Eye Rest Configuration" />
                            <TextBlock Classes="SectionSubtitle" Text="Customize your short breaks to reduce eye strain." />
                        </StackPanel>
                        <!-- Tab 1 title -->
                        <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}">
                            <TextBlock Classes="SectionTitle" Text="Time Break Configuration" />
                            <TextBlock Classes="SectionSubtitle" Text="Configure your longer breaks for maximum productivity." />
                        </StackPanel>
                        <!-- Tab 2 title -->
                        <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2}">
                            <TextBlock Classes="SectionTitle" Text="Advanced Settings" />
                            <TextBlock Classes="SectionSubtitle" Text="Fine-tune application behavior and preferences." />
                        </StackPanel>
                        <!-- Tab 3 title -->
                        <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3}">
                            <TextBlock Classes="SectionTitle" Text="Analytics Dashboard" />
                            <TextBlock Classes="SectionSubtitle" Text="View your break compliance metrics." />
                        </StackPanel>
                    </StackPanel>

                    <!-- Scrollable Content -->
                    <ScrollViewer x:Name="ConfigContentScrollViewer" Grid.Row="1" Padding="32,0,32,0">
                        <Panel Margin="0,0,0,64">
                            <!-- ============================================ -->
                            <!-- Tab 0: Eye Rest Configuration                 -->
                            <!-- ============================================ -->
                            <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0}">

                                <!-- Rest Interval + Duration Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="20">
                                        <!-- Rest Interval -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Rest Interval" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Minimum="1" Maximum="60"
                                                        Value="{Binding EyeRestIntervalMinutes}"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" />
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-15,0,0">
                                                    <TextBlock Grid.Column="0" Text="1 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="60 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding EyeRestIntervalMinutes}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="minutes" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Duration -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Duration" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Minimum="5" Maximum="60"
                                                        Value="{Binding EyeRestDurationSeconds}"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-15,0,0">
                                                    <TextBlock Grid.Column="0" Text="5 sec" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="60 sec" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding EyeRestDurationSeconds}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="seconds" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Toggle Cards: Sound Alerts + Notification -->
                                <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                    <Border Grid.Column="0" Classes="ToggleCard" Margin="0,0,8,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ToggleCardIconBackground}"
                                                    VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource VolumeIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Sound Alerts" FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding EyeRestStartSoundEnabled, Converter={StaticResource BoolToTextConverter}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding EyeRestStartSoundEnabled}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1" Classes="ToggleCard" Margin="8,0,0,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ToggleCardIconBackground}"
                                                    VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource NotificationIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Show Notification" FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding EyeRestWarningEnabled, Converter={StaticResource BoolToTextConverter}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding EyeRestWarningEnabled}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Warning + End Sound Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="16">
                                        <!-- Warning Time -->
                                        <Grid ColumnDefinitions="*,Auto"
                                              IsEnabled="{Binding EyeRestWarningEnabled}">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Warning Time" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Minimum="5" Maximum="120"
                                                        Value="{Binding EyeRestWarningSeconds}"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding EyeRestWarningSeconds}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="sec" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- End Sound Toggle -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="32" Height="32"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource ToggleCardIconBackground}">
                                                <PathIcon Data="{StaticResource VolumeIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="End Sound" Margin="12,0,0,0"
                                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding EyeRestEndSoundEnabled}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Info Card: Tip -->
                                <Border Classes="InfoCard">
                                    <StackPanel Orientation="Horizontal" Spacing="14">
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="{DynamicResource ToggleCardIconBackground}">
                                            <PathIcon Data="{StaticResource VisibilityIcon}" Width="20" Height="20"
                                                      Foreground="{DynamicResource ToggleCardIconColor}" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Time for an Eye Rest!" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="Look away for 20s at something 20 feet away."
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Test Controls Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Test Controls" FontSize="14" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Classes="ActionBtnWarning"
                                                    Command="{Binding TestWarningCommand}"
                                                    ToolTip.Tip="Test the eye rest warning notification">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Data="{StaticResource WarningTestIcon}" Width="14" Height="14" />
                                                    <TextBlock Text="Test Warning" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="ActionBtnPrimary"
                                                    Command="{Binding TestPopupCommand}"
                                                    ToolTip.Tip="Test the eye rest popup">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Data="{StaticResource EyeIcon}" Width="14" Height="14" />
                                                    <TextBlock Text="Test Eye Rest" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================================ -->
                            <!-- Tab 1: Time Break Configuration               -->
                            <!-- ============================================ -->
                            <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}">

                                <!-- Work Interval + Break Duration Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="20">
                                        <!-- Work Interval -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Work Interval" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Minimum="1" Maximum="120"
                                                        Value="{Binding BreakIntervalMinutes}"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" />
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-15,0,0">
                                                    <TextBlock Grid.Column="0" Text="1 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="120 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding BreakIntervalMinutes}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="minutes" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Break Duration -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Break Duration" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Minimum="1" Maximum="30"
                                                        Value="{Binding BreakDurationMinutes}"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" />
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-15,0,0">
                                                    <TextBlock Grid.Column="0" Text="1 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="30 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding BreakDurationMinutes}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="minutes" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Toggle Cards: Warning + Confirmation -->
                                <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                    <Border Grid.Column="0" Classes="ToggleCard" Margin="0,0,8,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ToggleCardIconBackground}"
                                                    VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource NotificationIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Warning" FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding BreakWarningEnabled, Converter={StaticResource BoolToTextConverter}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding BreakWarningEnabled}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1" Classes="ToggleCard" Margin="8,0,0,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ToggleCardIconBackground}"
                                                    VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource ClockIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Confirmation" FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding RequireConfirmationAfterBreak, Converter={StaticResource BoolToTextConverter}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding RequireConfirmationAfterBreak}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Overlay + Warning Time + Reset Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="16">
                                        <!-- Overlay Opacity -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Overlay Opacity" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Minimum="0" Maximum="100"
                                                        Value="{Binding OverlayOpacityPercent}"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="2">
                                                    <TextBlock Text="{Binding OverlayOpacityPercent}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="%" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Warning Time -->
                                        <Grid ColumnDefinitions="*,Auto"
                                              IsEnabled="{Binding BreakWarningEnabled}">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Warning Time" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Minimum="5" Maximum="300"
                                                        Value="{Binding BreakWarningSeconds}"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding BreakWarningSeconds}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="sec" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Reset on Confirmation Toggle -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="32" Height="32"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource ToggleCardIconBackground}">
                                                <PathIcon Data="{StaticResource ResetIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Reset Timers on Confirm" Margin="12,0,0,0"
                                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding ResetTimersOnBreakConfirmation}"
                                                          IsEnabled="{Binding RequireConfirmationAfterBreak}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Info Card: Break tip -->
                                <Border Classes="InfoCard">
                                    <StackPanel Orientation="Horizontal" Spacing="14">
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="{DynamicResource ToggleCardIconBackground}">
                                            <PathIcon Data="{StaticResource InfoIcon}" Width="20" Height="20"
                                                      Foreground="{DynamicResource ToggleCardIconColor}" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Time for a Break!" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="Enable both confirmation options for the best break experience."
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Test Controls Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Test Controls" FontSize="14" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Classes="ActionBtnWarning"
                                                    Command="{Binding TestBreakWarningCommand}"
                                                    ToolTip.Tip="Test the break warning notification">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Data="{StaticResource WarningTestIcon}" Width="14" Height="14" />
                                                    <TextBlock Text="Test Warning" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="ActionBtnPrimary"
                                                    Command="{Binding TestBreakCommand}"
                                                    ToolTip.Tip="Test the break popup">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" />
                                                    <TextBlock Text="Test Break" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================================ -->
                            <!-- Tab 2: Advanced Settings                      -->
                            <!-- ============================================ -->
                            <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2}">

                                <!-- Smart Pause Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Smart Pause" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="Automatically pause timers when you're away."
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Pause on Screen Lock" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding PauseOnScreenLock}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Pause on Monitor Off" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding PauseOnMonitorOff}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Pause on Idle" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding PauseOnIdle}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <!-- Idle Timeout Slider -->
                                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding PauseOnIdle}" Margin="28,0,0,0">
                                            <StackPanel Grid.Column="0" Spacing="6">
                                                <TextBlock Text="Idle Timeout" FontSize="15" FontWeight="Medium" />
                                                <Slider Minimum="1" Maximum="60"
                                                        Value="{Binding IdleTimeoutMinutes}"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding IdleTimeoutMinutes}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="min" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Audio Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Audio" FontSize="16" FontWeight="SemiBold" />

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource VolumeIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Enable Audio" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding AudioEnabled}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <StackPanel IsEnabled="{Binding AudioEnabled}" Spacing="12">
                                            <!-- Volume -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="6">
                                                    <TextBlock Text="Volume" FontSize="15" FontWeight="Medium" />
                                                    <Slider Minimum="0" Maximum="100"
                                                            Value="{Binding AudioVolume}"
                                                            TickFrequency="5" IsSnapToTickEnabled="True" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Classes="SliderBadge"
                                                        VerticalAlignment="Top" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                                        <TextBlock Text="{Binding AudioVolume}"
                                                                   FontWeight="Bold" FontSize="14"
                                                                   Foreground="{DynamicResource SliderBadgeText}" />
                                                        <TextBlock Text="%" FontSize="12"
                                                                   Foreground="{DynamicResource SliderBadgeText}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- Custom Sound -->
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Custom Sound" FontSize="15" FontWeight="Medium" />
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding CustomSoundPath}"
                                                             IsReadOnly="True"
                                                             ToolTip.Tip="Path to custom audio file" />
                                                    <Button Grid.Column="1" Classes="ActionBtnPrimary"
                                                            Command="{Binding BrowseCustomAudioCommand}"
                                                            Margin="8,0,0,0"
                                                            ToolTip.Tip="Browse for audio file">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <PathIcon Data="{StaticResource BrowseIcon}" Width="14" Height="14" />
                                                            <TextBlock Text="Browse" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Column="2" Classes="ActionBtn"
                                                            Command="{Binding TestCustomAudioCommand}"
                                                            Margin="8,0,0,0"
                                                            ToolTip.Tip="Test audio">
                                                        <TextBlock Text="Test" />
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- BL-002: Popup Audio Card (per-channel source picker + retained alternates) -->
                                <Border Classes="GlassCard">
                                    <Border.Styles>
                                        <!-- Theme the TextBoxes inside this card to match the GlassCard surface:
                                             white text (matches all other glass-card content per GlassStyles.axaml),
                                             vertically centered glyphs, and a min-height so the input box matches
                                             the height of the adjacent RadioButton row visually. Scoped to this
                                             Border so the rest of the app's TextBoxes are unaffected. -->
                                        <Style Selector="TextBox">
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="CaretBrush" Value="White" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                            <Setter Property="MinHeight" Value="34" />
                                            <Setter Property="Padding" Value="10,0" />
                                        </Style>
                                    </Border.Styles>
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Popup Audio" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="Per-popup audio source. Bundled defaults ship with the app; pick a file or URL to override."
                                                   Opacity="0.7" FontSize="12" TextWrapping="Wrap" />

                                        <!-- Eye-rest Start -->
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Eye-rest Start" FontSize="14" FontWeight="Medium" />
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <RadioButton GroupName="EyeRestStartSource" Content="Default" IsChecked="{Binding EyeRestStartSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Default}" />
                                                <RadioButton GroupName="EyeRestStartSource" Content="File"    IsChecked="{Binding EyeRestStartSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=File}" />
                                                <RadioButton GroupName="EyeRestStartSource" Content="URL"     IsChecked="{Binding EyeRestStartSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Url}" />
                                                <RadioButton GroupName="EyeRestStartSource" Content="Off"     IsChecked="{Binding EyeRestStartSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Off}" />
                                                <Button Classes="ActionBtn" Content="Test" Command="{Binding TestEyeRestStartChannelCommand}" />
                                            </StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding EyeRestStartFilePath}" Watermark="File path (when Source = File)" />
                                                <Button Grid.Column="1" Classes="ActionBtnPrimary" Content="Browse" Margin="8,0,0,0"
                                                        Command="{Binding BrowseEyeRestStartFileCommand}"
                                                        IsVisible="{Binding EyeRestStartSource, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=File}" />
                                            </Grid>
                                            <TextBox Text="{Binding EyeRestStartUrl}" Watermark="URL (when Source = URL)" />
                                        </StackPanel>

                                        <!-- Eye-rest End -->
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Eye-rest End" FontSize="14" FontWeight="Medium" />
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <RadioButton GroupName="EyeRestEndSource" Content="Default" IsChecked="{Binding EyeRestEndSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Default}" />
                                                <RadioButton GroupName="EyeRestEndSource" Content="File"    IsChecked="{Binding EyeRestEndSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=File}" />
                                                <RadioButton GroupName="EyeRestEndSource" Content="URL"     IsChecked="{Binding EyeRestEndSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Url}" />
                                                <RadioButton GroupName="EyeRestEndSource" Content="Off"     IsChecked="{Binding EyeRestEndSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Off}" />
                                                <Button Classes="ActionBtn" Content="Test" Command="{Binding TestEyeRestEndChannelCommand}" />
                                            </StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding EyeRestEndFilePath}" Watermark="File path (when Source = File)" />
                                                <Button Grid.Column="1" Classes="ActionBtnPrimary" Content="Browse" Margin="8,0,0,0"
                                                        Command="{Binding BrowseEyeRestEndFileCommand}"
                                                        IsVisible="{Binding EyeRestEndSource, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=File}" />
                                            </Grid>
                                            <TextBox Text="{Binding EyeRestEndUrl}" Watermark="URL (when Source = URL)" />
                                        </StackPanel>

                                        <!-- Break Start -->
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Break Start" FontSize="14" FontWeight="Medium" />
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <RadioButton GroupName="BreakStartSource" Content="Default" IsChecked="{Binding BreakStartSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Default}" />
                                                <RadioButton GroupName="BreakStartSource" Content="File"    IsChecked="{Binding BreakStartSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=File}" />
                                                <RadioButton GroupName="BreakStartSource" Content="URL"     IsChecked="{Binding BreakStartSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Url}" />
                                                <RadioButton GroupName="BreakStartSource" Content="Off"     IsChecked="{Binding BreakStartSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Off}" />
                                                <Button Classes="ActionBtn" Content="Test" Command="{Binding TestBreakStartChannelCommand}" />
                                            </StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding BreakStartFilePath}" Watermark="File path (when Source = File)" />
                                                <Button Grid.Column="1" Classes="ActionBtnPrimary" Content="Browse" Margin="8,0,0,0"
                                                        Command="{Binding BrowseBreakStartFileCommand}"
                                                        IsVisible="{Binding BreakStartSource, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=File}" />
                                            </Grid>
                                            <TextBox Text="{Binding BreakStartUrl}" Watermark="URL (when Source = URL) — e.g. YouTube playlist" />
                                        </StackPanel>

                                        <!-- Break End -->
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Break End" FontSize="14" FontWeight="Medium" />
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <RadioButton GroupName="BreakEndSource" Content="Default" IsChecked="{Binding BreakEndSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Default}" />
                                                <RadioButton GroupName="BreakEndSource" Content="File"    IsChecked="{Binding BreakEndSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=File}" />
                                                <RadioButton GroupName="BreakEndSource" Content="URL"     IsChecked="{Binding BreakEndSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Url}" />
                                                <RadioButton GroupName="BreakEndSource" Content="Off"     IsChecked="{Binding BreakEndSource, Mode=TwoWay, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=Off}" />
                                                <Button Classes="ActionBtn" Content="Test" Command="{Binding TestBreakEndChannelCommand}" />
                                            </StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding BreakEndFilePath}" Watermark="File path (when Source = File)" />
                                                <Button Grid.Column="1" Classes="ActionBtnPrimary" Content="Browse" Margin="8,0,0,0"
                                                        Command="{Binding BrowseBreakEndFileCommand}"
                                                        IsVisible="{Binding BreakEndSource, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter=File}" />
                                            </Grid>
                                            <TextBox Text="{Binding BreakEndUrl}" Watermark="URL (when Source = URL)" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Application Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Application" FontSize="16" FontWeight="SemiBold" />

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Start with System" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding StartWithWindows}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Start Minimized" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding StartMinimized}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Minimize to Tray" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding MinimizeToTray}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource NotificationIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Tray Notifications" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding ShowTrayNotifications}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Theme Card -->
                                <Border Classes="GlassCard">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                CornerRadius="10"
                                                Background="{DynamicResource ToggleCardIconBackground}">
                                            <PathIcon Data="{StaticResource DarkModeIcon}" Width="18" Height="18"
                                                      Foreground="{DynamicResource ToggleCardIconColor}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Theme" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="Auto follows your system appearance"
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding ThemeModes}"
                                                  SelectedItem="{Binding SelectedThemeMode}"
                                                  VerticalAlignment="Center"
                                                  MinWidth="100" />
                                    </Grid>
                                </Border>

                                <!-- Reset Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Reset Settings" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="Restore all settings to their default values."
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <Button Classes="ActionBtnWarning"
                                                Command="{Binding RestoreDefaultsCommand}"
                                                ToolTip.Tip="Reset all settings to defaults"
                                                HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <PathIcon Data="{StaticResource ResetIcon}" Width="14" Height="14" />
                                                <TextBlock Text="Restore Defaults" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================================ -->
                            <!-- Tab 3: Analytics                              -->
                            <!-- ============================================ -->
                            <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3}"
                                        Spacing="8" Margin="0,8,0,0">

                                <!-- Section Header with Period Selector -->
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="Key Performance Metrics"
                                               FontSize="15" FontWeight="SemiBold"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button Classes="PeriodPill"
                                                Classes.active="{Binding IsAnalyticsPeriod7}"
                                                Command="{Binding SetAnalyticsPeriodCommand}"
                                                CommandParameter="7">
                                            <TextBlock Text="7d" />
                                        </Button>
                                        <Button Classes="PeriodPill"
                                                Classes.active="{Binding IsAnalyticsPeriod30}"
                                                Command="{Binding SetAnalyticsPeriodCommand}"
                                                CommandParameter="30">
                                            <TextBlock Text="30d" />
                                        </Button>
                                        <Button Classes="PeriodPill"
                                                Classes.active="{Binding IsAnalyticsPeriod90}"
                                                Command="{Binding SetAnalyticsPeriodCommand}"
                                                CommandParameter="90">
                                            <TextBlock Text="90d" />
                                        </Button>
                                        <Button Classes="PeriodPill"
                                                Classes.active="{Binding IsAnalyticsPeriodAll}"
                                                Command="{Binding SetAnalyticsPeriodCommand}"
                                                CommandParameter="0">
                                            <TextBlock Text="All" />
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 1: Compliance Rate | Breaks Completed -->
                                <Grid ColumnDefinitions="*,6,*">
                                    <!-- Compliance Rate Card -->
                                    <Border Grid.Column="0" Classes="GlassCard" Padding="12,10">
                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding AnalyticsComplianceRateText}"
                                                       FontSize="24" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Compliance Rate"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <ProgressBar Value="{Binding AnalyticsComplianceRateValue}"
                                                         Maximum="100"
                                                         Height="3"
                                                         Margin="0,4,0,0"
                                                         Background="{DynamicResource ControlBorderBrush}"
                                                         Foreground="{DynamicResource PrimaryBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Breaks Completed Card -->
                                    <Border Grid.Column="2" Classes="GlassCard" Padding="12,10">
                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding AnalyticsTotalBreaksCompleted}"
                                                       FontSize="24" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Breaks Completed"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding AnalyticsCompletedPercentageText}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding BreaksAutoManualSummary}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Row 2: Breaks Skipped | Total Active Time -->
                                <Grid ColumnDefinitions="*,6,*">
                                    <!-- Breaks Skipped Card -->
                                    <Border Grid.Column="0" Classes="GlassCard" Padding="12,10">
                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding AnalyticsTotalBreaksSkipped}"
                                                       FontSize="24" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ErrorBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Breaks Skipped"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding AnalyticsSkippedPercentageText}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Total Active Time Card -->
                                    <Border Grid.Column="2" Classes="GlassCard" Padding="12,10">
                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding AnalyticsTotalActiveTimeText}"
                                                       FontSize="24" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Total Active Time"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding AnalyticsDailyAverageText}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Row 3: Eye Health Score (full width) -->
                                <Border Classes="GlassCard" Padding="12,10">
                                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding AnalyticsHealthScoreText}"
                                                   FontSize="24" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="Eye Health Score"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" />
                                        <Border Background="{DynamicResource AccentBrush}"
                                                CornerRadius="10"
                                                Padding="8,2"
                                                HorizontalAlignment="Center"
                                                Margin="0,4,0,0">
                                            <TextBlock Text="{Binding AnalyticsHealthStatusText}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFFFFF"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- View Details opens full Analytics Dashboard with Event History tab -->
                                <Button Classes="ActionBtnPrimary"
                                        Command="{Binding ShowAnalyticsCommand}"
                                        HorizontalAlignment="Stretch"
                                        Height="38" Margin="0,4,0,0"
                                        ToolTip.Tip="Open full analytics dashboard with event history and detailed charts">
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ChartIcon}" Width="14" Height="14" />
                                        <TextBlock Text="View Details" FontSize="13" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- ============================================ -->
                            <!-- Error Message Overlay (bottom)                -->
                            <!-- ============================================ -->
                            <Border VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,8"
                                    IsVisible="{Binding HasValidationErrors}"
                                    Background="{DynamicResource ErrorBrush}"
                                    CornerRadius="10"
                                    Padding="16,10"
                                    MaxWidth="600">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Warning:"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               FontSize="15"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Panel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            </Panel>
            <!-- Info toast message (auto-dismiss, overlays without pushing content) -->
            <Panel Grid.Row="1"
                   IsVisible="{Binding HasInfoMessage}"
                   IsHitTestVisible="False"
                   ZIndex="100">
                <Border Background="#E0336699"
                        CornerRadius="8"
                        Padding="14,10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="16,40,16,0"
                        MaxWidth="500">
                    <TextBlock Text="{Binding InfoMessage}"
                               Foreground="White"
                               FontSize="12"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                </Border>
            </Panel>

            <!-- Dim overlay for modal dialogs (75% black) -->
            <Border Name="DimOverlay"
                    Grid.RowSpan="2"
                    Background="#BF000000"
                    IsVisible="False"
                    IsHitTestVisible="False" />

        </Grid>
    </Border>
</Window>
