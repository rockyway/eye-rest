<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EyeRest.UI.ViewModels"
        xmlns:converters="using:EyeRest.UI.Converters"
        x:Class="EyeRest.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Width="900" Height="700"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="40"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <converters:EqualityConverter x:Key="EqualityConverter" />
        <converters:BoolToTextConverter x:Key="BoolToTextConverter" />
    </Window.Resources>

    <!-- Outer border with mesh gradient background and rounded corners -->
    <!-- CornerRadius=10 matches macOS native window corner radius to avoid gaps -->
    <Border Background="{DynamicResource MeshGradientBrush}"
            CornerRadius="10"
            ClipToBounds="True">

        <Grid RowDefinitions="40,*">

            <!-- ============================================================ -->
            <!-- Row 0: Custom Title Bar                                       -->
            <!-- ============================================================ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBackground}"
                    PointerPressed="TitleBar_PointerPressed">
                <Grid>
                    <!-- Centered: App icon + title -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Image Source="avares://EyeRest.UI/Assets/TrayIcons/tray_active@2x.png"
                               Width="18" Height="18" />
                        <TextBlock Text="Eye Rest"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Right: Window control buttons (Windows only) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                IsVisible="{OnPlatform False, Windows=True}">
                        <Button Classes="CaptionBtn" Click="MinimizeButton_Click"
                                ToolTip.Tip="Minimize">
                            <PathIcon Data="M4,12 L20,12" Width="10" Height="10"
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                        <Button Classes="CaptionBtn" Click="MaximizeButton_Click"
                                ToolTip.Tip="Maximize">
                            <PathIcon Data="{StaticResource MaximizeIcon}" Width="10" Height="10"
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                        <Button Classes="CaptionBtn CaptionCloseBtn" Click="CloseButton_Click"
                                ToolTip.Tip="Close">
                            <PathIcon Data="{StaticResource CloseIcon}" Width="10" Height="10"
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================================ -->
            <!-- Row 1: Main Content (Sidebar + Content)                       -->
            <!-- ============================================================ -->
            <Grid Grid.Row="1" ColumnDefinitions="260,*">

                <!-- ======================================================== -->
                <!-- Col 0: Sidebar                                            -->
                <!-- ======================================================== -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="{DynamicResource GlassPanelBorder}"
                        BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">

                        <!-- Nav Buttons -->
                        <StackPanel Grid.Row="0" Margin="0,12,0,0">
                            <Button Classes="NavButton"
                                    Classes.active="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0}"
                                    Tag="0" Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource EyeIcon}" Width="18" Height="18" />
                                    <TextBlock Text="Eye Rest" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="NavButton"
                                    Classes.active="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}"
                                    Tag="1" Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource ClockIcon}" Width="18" Height="18" />
                                    <TextBlock Text="Time Break" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="NavButton"
                                    Classes.active="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2}"
                                    Tag="2" Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource TuneIcon}" Width="18" Height="18" />
                                    <TextBlock Text="Advanced" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="NavButton"
                                    Classes.active="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3}"
                                    Tag="3" Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource ChartIcon}" Width="18" Height="18" />
                                    <TextBlock Text="Analytics" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Status Card -->
                        <Border Grid.Row="1" Classes="StatusCard" Margin="8,16,8,0">
                            <StackPanel Spacing="6">
                                <!-- Status Row -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="STATUS" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding TimerStatusText}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding TimerStatusColor}"
                                             VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Countdown Timers - each on its own line -->
                                <StackPanel IsVisible="{Binding IsRunning}" Spacing="1">
                                    <TextBlock Text="{Binding TimeUntilNextEyeRest}"
                                               FontSize="11"
                                               FontFamily="Consolas,Menlo,monospace"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding TimeUntilNextBreak}"
                                               FontSize="11"
                                               FontFamily="Consolas,Menlo,monospace"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Spacer -->
                        <Panel Grid.Row="2" />

                        <!-- Bottom: Dark toggle + Meeting + Controls + Exit -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,12" Spacing="4">

                            <!-- Dark Mode Toggle -->
                            <Border Margin="8,0" Padding="12,6"
                                    Background="{DynamicResource StatusCardBackground}"
                                    BorderBrush="{DynamicResource StatusCardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <PathIcon Grid.Column="0"
                                              Data="{StaticResource DarkModeIcon}"
                                              Width="16" Height="16"
                                              Foreground="{DynamicResource ToggleCardIconColor}"
                                              VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Dark Mode"
                                               FontSize="12" FontWeight="Medium"
                                               VerticalAlignment="Center" Margin="10,0,0,0" />
                                    <ToggleSwitch Grid.Column="2"
                                                  IsChecked="{Binding IsDarkMode}"
                                                  VerticalAlignment="Center"
                                                  OnContent="" OffContent=""
                                                  Margin="0,-2,0,-2" />
                                </Grid>
                            </Border>

                            <!-- Meeting Buttons - styled as clear pill buttons -->
                            <Grid ColumnDefinitions="*,*" Margin="8,4,8,4">
                                <Button Grid.Column="0" Classes="MeetingBtn"
                                        Command="{Binding PauseForMeetingCommand}"
                                        IsEnabled="{Binding CanPauseMeeting}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding Meeting30mButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" />
                                        <TextBlock Text="Meet 30m" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Classes="MeetingBtn"
                                        Command="{Binding PauseForMeeting1hCommand}"
                                        IsEnabled="{Binding CanPauseMeeting}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding Meeting1hButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" />
                                        <TextBlock Text="Meet 1h" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Start Button (full width) -->
                            <Button Classes="GradientStart"
                                    Command="{Binding StartTimersCommand}"
                                    ToolTip.Tip="{Binding StartButtonTooltip}">
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="{StaticResource PlayIcon}" Width="14" Height="14" Foreground="White" />
                                    <TextBlock Text="Start" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <!-- Stop + Pause row -->
                            <Grid ColumnDefinitions="*,*" Margin="4,0">
                                <Button Grid.Column="0" Classes="GradientStop"
                                        Command="{Binding StopTimersCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding StopButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource StopIcon}" Width="12" Height="12" Foreground="White" />
                                        <TextBlock Text="Stop" Foreground="White" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Classes="GradientPause"
                                        Command="{Binding PauseTimersCommand}"
                                        IsEnabled="{Binding CanPauseTimers}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding PauseButtonTooltip}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource PauseIcon}" Width="12" Height="12" Foreground="White" />
                                        <TextBlock Text="Pause" Foreground="White" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Resume button (visible when paused) -->
                            <Button Classes="GradientStart"
                                    Command="{Binding ResumeTimersCommand}"
                                    IsEnabled="{Binding CanResumeTimers}"
                                    IsVisible="{Binding CanResumeTimers}"
                                    ToolTip.Tip="{Binding ResumeButtonTooltip}"
                                    Height="36" Margin="8,0">
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="{StaticResource PlayIcon}" Width="12" Height="12" Foreground="White" />
                                    <TextBlock Text="Resume" Foreground="White" FontSize="13" />
                                </StackPanel>
                            </Button>

                            <!-- Exit button -->
                            <Button Margin="8,4,8,0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Height="30"
                                    CornerRadius="8"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Command="{Binding ExitApplicationCommand}"
                                    ToolTip.Tip="Exit application"
                                    FontSize="12" Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="{StaticResource ExitIcon}" Width="14" Height="14"
                                              Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="Exit" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ======================================================== -->
                <!-- Col 1: Content Area                                       -->
                <!-- ======================================================== -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*">

                    <!-- Fixed Title Section -->
                    <StackPanel Grid.Row="0" Margin="32,24,32,0">
                        <!-- Tab 0 title -->
                        <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0}">
                            <TextBlock Classes="SectionTitle" Text="Eye Rest Configuration" />
                            <TextBlock Classes="SectionSubtitle" Text="Customize your short breaks to reduce eye strain." />
                        </StackPanel>
                        <!-- Tab 1 title -->
                        <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}">
                            <TextBlock Classes="SectionTitle" Text="Time Break Configuration" />
                            <TextBlock Classes="SectionSubtitle" Text="Configure your longer breaks for maximum productivity." />
                        </StackPanel>
                        <!-- Tab 2 title -->
                        <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2}">
                            <TextBlock Classes="SectionTitle" Text="Advanced Settings" />
                            <TextBlock Classes="SectionSubtitle" Text="Fine-tune application behavior and preferences." />
                        </StackPanel>
                        <!-- Tab 3 title -->
                        <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3}">
                            <TextBlock Classes="SectionTitle" Text="Analytics Dashboard" />
                            <TextBlock Classes="SectionSubtitle" Text="View your break compliance metrics." />
                        </StackPanel>
                    </StackPanel>

                    <!-- Scrollable Content -->
                    <ScrollViewer Grid.Row="1" Padding="32,0,32,0">
                        <Panel Margin="0,0,0,64">
                            <!-- ============================================ -->
                            <!-- Tab 0: Eye Rest Configuration                 -->
                            <!-- ============================================ -->
                            <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0}">

                                <!-- Rest Interval + Duration Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="20">
                                        <!-- Rest Interval -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Rest Interval" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Value="{Binding EyeRestIntervalMinutes}"
                                                        Minimum="1" Maximum="60"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" />
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-15,0,0">
                                                    <TextBlock Grid.Column="0" Text="1 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="60 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding EyeRestIntervalMinutes}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="minutes" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Duration -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Duration" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Value="{Binding EyeRestDurationSeconds}"
                                                        Minimum="5" Maximum="60"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-15,0,0">
                                                    <TextBlock Grid.Column="0" Text="5 sec" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="60 sec" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding EyeRestDurationSeconds}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="seconds" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Toggle Cards: Sound Alerts + Notification -->
                                <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                    <Border Grid.Column="0" Classes="ToggleCard" Margin="0,0,8,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ToggleCardIconBackground}"
                                                    VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource VolumeIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Sound Alerts" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding EyeRestStartSoundEnabled, Converter={StaticResource BoolToTextConverter}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding EyeRestStartSoundEnabled}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1" Classes="ToggleCard" Margin="8,0,0,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ToggleCardIconBackground}"
                                                    VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource NotificationIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Show Notification" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding EyeRestWarningEnabled, Converter={StaticResource BoolToTextConverter}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding EyeRestWarningEnabled}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Warning + End Sound Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="16">
                                        <!-- Warning Time -->
                                        <Grid ColumnDefinitions="*,Auto"
                                              IsEnabled="{Binding EyeRestWarningEnabled}">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Warning Time" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Value="{Binding EyeRestWarningSeconds}"
                                                        Minimum="5" Maximum="120"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding EyeRestWarningSeconds}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="sec" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- End Sound Toggle -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="32" Height="32"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource ToggleCardIconBackground}">
                                                <PathIcon Data="{StaticResource VolumeIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="End Sound" Margin="12,0,0,0"
                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding EyeRestEndSoundEnabled}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Info Card: Tip -->
                                <Border Classes="InfoCard">
                                    <StackPanel Orientation="Horizontal" Spacing="14">
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="{DynamicResource ToggleCardIconBackground}">
                                            <PathIcon Data="{StaticResource VisibilityIcon}" Width="20" Height="20"
                                                      Foreground="{DynamicResource ToggleCardIconColor}" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Time for an Eye Rest!" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="Look away for 20s at something 20 feet away."
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Test Controls Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Test Controls" FontSize="14" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Classes="ActionBtnWarning"
                                                    Command="{Binding TestWarningCommand}"
                                                    ToolTip.Tip="Test the eye rest warning notification">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Data="{StaticResource WarningTestIcon}" Width="14" Height="14" />
                                                    <TextBlock Text="Test Warning" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="ActionBtnPrimary"
                                                    Command="{Binding TestPopupCommand}"
                                                    ToolTip.Tip="Test the eye rest popup">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Data="{StaticResource EyeIcon}" Width="14" Height="14" />
                                                    <TextBlock Text="Test Eye Rest" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================================ -->
                            <!-- Tab 1: Time Break Configuration               -->
                            <!-- ============================================ -->
                            <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}">

                                <!-- Work Interval + Break Duration Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="20">
                                        <!-- Work Interval -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Work Interval" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Value="{Binding BreakIntervalMinutes}"
                                                        Minimum="1" Maximum="120"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-15,0,0">
                                                    <TextBlock Grid.Column="0" Text="1 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="120 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding BreakIntervalMinutes}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="minutes" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Break Duration -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Break Duration" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Value="{Binding BreakDurationMinutes}"
                                                        Minimum="1" Maximum="30"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" />
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-15,0,0">
                                                    <TextBlock Grid.Column="0" Text="1 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="30 min" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding BreakDurationMinutes}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="minutes" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Toggle Cards: Warning + Confirmation -->
                                <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                    <Border Grid.Column="0" Classes="ToggleCard" Margin="0,0,8,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ToggleCardIconBackground}"
                                                    VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource NotificationIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Warning" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding BreakWarningEnabled, Converter={StaticResource BoolToTextConverter}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding BreakWarningEnabled}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1" Classes="ToggleCard" Margin="8,0,0,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ToggleCardIconBackground}"
                                                    VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource ClockIcon}" Width="18" Height="18"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Confirmation" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding RequireConfirmationAfterBreak, Converter={StaticResource BoolToTextConverter}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding RequireConfirmationAfterBreak}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Overlay + Warning Time + Reset Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="16">
                                        <!-- Overlay Opacity -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Overlay Opacity" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Value="{Binding OverlayOpacityPercent}"
                                                        Minimum="0" Maximum="100"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="2">
                                                    <TextBlock Text="{Binding OverlayOpacityPercent}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="%" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Warning Time -->
                                        <Grid ColumnDefinitions="*,Auto"
                                              IsEnabled="{Binding BreakWarningEnabled}">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Warning Time" FontSize="14" FontWeight="SemiBold" />
                                                <Slider Value="{Binding BreakWarningSeconds}"
                                                        Minimum="5" Maximum="300"
                                                        TickFrequency="5" IsSnapToTickEnabled="True" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding BreakWarningSeconds}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="sec" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Reset on Confirmation Toggle -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="32" Height="32"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource ToggleCardIconBackground}">
                                                <PathIcon Data="{StaticResource ResetIcon}" Width="16" Height="16"
                                                          Foreground="{DynamicResource ToggleCardIconColor}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Reset Timers on Confirm" Margin="12,0,0,0"
                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2"
                                                          IsChecked="{Binding ResetTimersOnBreakConfirmation}"
                                                          IsEnabled="{Binding RequireConfirmationAfterBreak}"
                                                          VerticalAlignment="Center"
                                                          OnContent="" OffContent="" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Info Card: Break tip -->
                                <Border Classes="InfoCard">
                                    <StackPanel Orientation="Horizontal" Spacing="14">
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="{DynamicResource ToggleCardIconBackground}">
                                            <PathIcon Data="{StaticResource InfoIcon}" Width="20" Height="20"
                                                      Foreground="{DynamicResource ToggleCardIconColor}" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Time for a Break!" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="Enable both confirmation options for the best break experience."
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Test Controls Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Test Controls" FontSize="14" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Classes="ActionBtnWarning"
                                                    Command="{Binding TestBreakWarningCommand}"
                                                    ToolTip.Tip="Test the break warning notification">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Data="{StaticResource WarningTestIcon}" Width="14" Height="14" />
                                                    <TextBlock Text="Test Warning" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="ActionBtnPrimary"
                                                    Command="{Binding TestBreakCommand}"
                                                    ToolTip.Tip="Test the break popup">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Data="{StaticResource ClockIcon}" Width="14" Height="14" />
                                                    <TextBlock Text="Test Break" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================================ -->
                            <!-- Tab 2: Advanced Settings                      -->
                            <!-- ============================================ -->
                            <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2}">

                                <!-- Smart Pause Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Smart Pause" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="Automatically pause timers when you're away."
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Pause on Screen Lock" FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding PauseOnScreenLock}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Pause on Monitor Off" FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding PauseOnMonitorOff}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Pause on Idle" FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding PauseOnIdle}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <!-- Idle Timeout Slider -->
                                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding PauseOnIdle}" Margin="28,0,0,0">
                                            <StackPanel Grid.Column="0" Spacing="6">
                                                <TextBlock Text="Idle Timeout" FontSize="13" FontWeight="Medium" />
                                                <Slider Value="{Binding IdleTimeoutMinutes}"
                                                        Minimum="1" Maximum="60"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Classes="SliderBadge"
                                                    VerticalAlignment="Top" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding IdleTimeoutMinutes}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                    <TextBlock Text="min" FontSize="12"
                                                               Foreground="{DynamicResource SliderBadgeText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Audio Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Audio" FontSize="16" FontWeight="SemiBold" />

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource VolumeIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Enable Audio" FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding AudioEnabled}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <StackPanel IsEnabled="{Binding AudioEnabled}" Spacing="12">
                                            <!-- Volume -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="6">
                                                    <TextBlock Text="Volume" FontSize="13" FontWeight="Medium" />
                                                    <Slider Value="{Binding AudioVolume}"
                                                            Minimum="0" Maximum="100"
                                                            TickFrequency="5" IsSnapToTickEnabled="True" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Classes="SliderBadge"
                                                        VerticalAlignment="Top" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                                        <TextBlock Text="{Binding AudioVolume}"
                                                                   FontWeight="Bold" FontSize="14"
                                                                   Foreground="{DynamicResource SliderBadgeText}" />
                                                        <TextBlock Text="%" FontSize="12"
                                                                   Foreground="{DynamicResource SliderBadgeText}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- Custom Sound -->
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Custom Sound" FontSize="13" FontWeight="Medium" />
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding CustomSoundPath}"
                                                             IsReadOnly="True"
                                                             ToolTip.Tip="Path to custom audio file" />
                                                    <Button Grid.Column="1" Classes="ActionBtnPrimary"
                                                            Command="{Binding BrowseCustomAudioCommand}"
                                                            Margin="8,0,0,0"
                                                            ToolTip.Tip="Browse for audio file">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <PathIcon Data="{StaticResource BrowseIcon}" Width="14" Height="14" />
                                                            <TextBlock Text="Browse" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Column="2" Classes="ActionBtn"
                                                            Command="{Binding TestCustomAudioCommand}"
                                                            Margin="8,0,0,0"
                                                            ToolTip.Tip="Test audio">
                                                        <TextBlock Text="Test" />
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Application Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Application" FontSize="16" FontWeight="SemiBold" />

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Start with System" FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding StartWithWindows}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Start Minimized" FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding StartMinimized}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource SettingsIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Minimize to Tray" FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding MinimizeToTray}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource NotificationIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource ToggleCardIconColor}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="Tray Notifications" FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="2" IsChecked="{Binding ShowTrayNotifications}"
                                                          VerticalAlignment="Center" OnContent="" OffContent="" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Theme Card -->
                                <Border Classes="GlassCard">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                CornerRadius="10"
                                                Background="{DynamicResource ToggleCardIconBackground}">
                                            <PathIcon Data="{StaticResource DarkModeIcon}" Width="18" Height="18"
                                                      Foreground="{DynamicResource ToggleCardIconColor}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Dark Mode" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="Switch between light and dark theme"
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="2"
                                                      IsChecked="{Binding IsDarkMode}"
                                                      VerticalAlignment="Center"
                                                      OnContent="" OffContent="" />
                                    </Grid>
                                </Border>

                                <!-- Reset Card -->
                                <Border Classes="GlassCard">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Reset Settings" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="Restore all settings to their default values."
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <Button Classes="ActionBtnWarning"
                                                Command="{Binding RestoreDefaultsCommand}"
                                                ToolTip.Tip="Reset all settings to defaults"
                                                HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <PathIcon Data="{StaticResource ResetIcon}" Width="14" Height="14" />
                                                <TextBlock Text="Restore Defaults" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================================ -->
                            <!-- Tab 3: Analytics                              -->
                            <!-- ============================================ -->
                            <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3}">

                                <Border Classes="GlassCard" Margin="0,40,0,0" HorizontalAlignment="Center"
                                        MaxWidth="500" Padding="40">
                                    <StackPanel HorizontalAlignment="Center" Spacing="16">
                                        <Border Width="64" Height="64" CornerRadius="32"
                                                Background="{DynamicResource ToggleCardIconBackground}"
                                                HorizontalAlignment="Center">
                                            <PathIcon Data="{StaticResource ChartIcon}" Width="32" Height="32"
                                                      Foreground="{DynamicResource ToggleCardIconColor}" />
                                        </Border>
                                        <TextBlock Text="Analytics Dashboard"
                                                   FontSize="20" FontWeight="Bold"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="View detailed break compliance metrics and performance analytics in a dedicated dashboard window."
                                                   FontSize="13"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   MaxWidth="360" />
                                        <Button Classes="ActionBtnPrimary"
                                                Command="{Binding ShowAnalyticsCommand}"
                                                HorizontalAlignment="Center"
                                                Height="44" Padding="24,8"
                                                ToolTip.Tip="Open the analytics dashboard">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <PathIcon Data="{StaticResource ChartIcon}" Width="16" Height="16" />
                                                <TextBlock Text="Open Dashboard" FontSize="14" />
                                            </StackPanel>
                                        </Button>
                                        <CheckBox Content="Auto-open dashboard when clicking Analytics tab"
                                                  IsChecked="{Binding AutoOpenDashboard}"
                                                  HorizontalAlignment="Center"
                                                  FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================================ -->
                            <!-- Error Message Overlay (bottom)                -->
                            <!-- ============================================ -->
                            <Border VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,8"
                                    IsVisible="{Binding HasValidationErrors}"
                                    Background="{DynamicResource ErrorBrush}"
                                    CornerRadius="10"
                                    Padding="16,10"
                                    MaxWidth="600">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Warning:"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Panel>
                    </ScrollViewer>
                </Grid>
            </Grid>
            <!-- Dim overlay for modal dialogs (75% black) -->
            <Border Name="DimOverlay"
                    Grid.RowSpan="2"
                    Background="#BF000000"
                    IsVisible="False"
                    IsHitTestVisible="False" />

        </Grid>
    </Border>
</Window>
