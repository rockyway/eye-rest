<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EyeRest.UI.Views.AboutWindow"
        Title="About Eye-Rest"
        Width="360"
        Height="490"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="False">

    <!-- Mesh gradient clipped to window shape -->
    <Border Background="{DynamicResource MeshGradientBrush}"
            CornerRadius="24"
            ClipToBounds="True"
            PointerPressed="OnDragMove">
        <!-- Glass overlay fills entire card -->
        <Border Background="{DynamicResource GlassCardBackground}"
                BorderBrush="{DynamicResource GlassCardBorder}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="24">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">

                    <Image Source="avares://EyeRest/Assets/app-icon.png"
                           Width="64" Height="64"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                    <TextBlock Text="Eye-Rest"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource NavButtonActiveText}"/>

                    <TextBlock x:Name="VersionText"
                               Text="Version ..."
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource ContentSubtitleText}"/>

                    <TextBlock x:Name="BuildTimestampText"
                               Text=""
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource ContentSubtitleText}"
                               Opacity="0.7"/>

                    <TextBlock Text="Automated eye rest and break reminders to keep your eyes healthy while working."
                               FontSize="13"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               MaxWidth="260"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource ContentSubtitleText}"/>

                    <TextBlock x:Name="WebsiteLink"
                               Text="eyerest.net"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               Cursor="Hand"
                               Foreground="{DynamicResource AccentBrush}"
                               TextDecorations="Underline"
                               PointerPressed="OnWebsiteLinkClick" />

                    <!-- Update Section -->
                    <StackPanel x:Name="UpdateSection" Spacing="4" Margin="0,4,0,4">
                        <Button x:Name="CheckForUpdatesButton"
                                Classes="ActionBtn"
                                HorizontalAlignment="Center"
                                Width="200"
                                Click="OnCheckForUpdatesClick"
                                Cursor="Hand">
                            <TextBlock x:Name="UpdateButtonText"
                                       Text="Check for Updates"
                                       FontSize="13"
                                       HorizontalAlignment="Center" />
                        </Button>
                        <TextBlock x:Name="UpdateStatusText"
                                   Text=""
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   MaxWidth="260"
                                   Foreground="{DynamicResource ContentSubtitleText}" />
                    </StackPanel>

                    <!-- Buy Me a Coffee Section (shown when not a supporter) -->
                    <StackPanel x:Name="DonateSection" Spacing="6" Margin="0,4,0,4">
                        <Grid ColumnDefinitions="*,8,*">
                            <Button Grid.Column="0"
                                    Classes="ActionBtnPrimary"
                                    HorizontalAlignment="Stretch"
                                    Click="OnDonateClick"
                                    Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="{StaticResource HeartIcon}"
                                              Width="14" Height="14"
                                              Foreground="{DynamicResource DonationHeartColor}" />
                                    <TextBlock Text="Buy Me a Coffee" FontSize="13" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    Classes="ActionBtn"
                                    HorizontalAlignment="Stretch"
                                    Click="OnEnterCodeClick"
                                    Cursor="Hand">
                                <TextBlock Text="Enter Code"
                                           FontSize="13"
                                           HorizontalAlignment="Center" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Supporter Badge (shown when verified supporter) -->
                    <Border x:Name="DonorBadgeSection"
                            IsVisible="False"
                            Background="{DynamicResource DonorBadgeBackground}"
                            BorderBrush="{DynamicResource DonorBadgeBorder}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16,8"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource CheckCircleIcon}"
                                      Width="16" Height="16"
                                      Foreground="{DynamicResource DonorBadgeText}" />
                            <TextBlock Text="Thank you for your support!"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DonorBadgeText}" />
                        </StackPanel>
                    </Border>

                    <Button Classes="GradientStart"
                            Width="120"
                            HorizontalAlignment="Center"
                            Click="OnCloseClick"
                            Cursor="Hand">
                        <TextBlock Text="Close"
                                   HorizontalAlignment="Center" />
                    </Button>

                </StackPanel>

                <!-- Close Button (top-right) -->
                <Button Classes="PopupCloseBtn"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-4,-4,0"
                        Click="OnCloseClick"
                        ToolTip.Tip="Close">
                    <PathIcon Data="{DynamicResource CloseIcon}"
                              Width="12" Height="12" />
                </Button>
            </Grid>
        </Border>
    </Border>
</Window>
