<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EyeRest.UI.Views.AboutWindow"
        Title="About Eye-Rest"
        Width="360"
        Height="340"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ExtendClientAreaToDecorationsHint="False">

    <!-- Mesh gradient clipped to window shape -->
    <Border Background="{DynamicResource MeshGradientBrush}"
            CornerRadius="24"
            ClipToBounds="True">
        <!-- Glass overlay fills entire card -->
        <Border Background="{DynamicResource GlassCardBackground}"
                BorderBrush="{DynamicResource GlassCardBorder}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="24">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">

                    <Image Source="avares://EyeRest.UI/Assets/app-icon.png"
                           Width="64" Height="64"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                    <TextBlock Text="Eye-Rest"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource NavButtonActiveText}"/>

                    <TextBlock x:Name="VersionText"
                               Text="Version 1.0.0"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource ContentSubtitleText}"/>

                    <TextBlock Text="Automated eye rest and break reminders to keep your eyes healthy while working."
                               FontSize="13"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               MaxWidth="260"
                               Margin="0,8,0,12"
                               Foreground="{DynamicResource ContentSubtitleText}"/>

                    <Button Classes="GradientStart"
                            Width="120"
                            HorizontalAlignment="Center"
                            Click="OnCloseClick"
                            Cursor="Hand">
                        <TextBlock Text="Close"
                                   HorizontalAlignment="Center" />
                    </Button>

                </StackPanel>

                <!-- Close Button (top-right) -->
                <Button Classes="PopupCloseBtn"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-4,-4,0"
                        Click="OnCloseClick"
                        ToolTip.Tip="Close">
                    <PathIcon Data="{DynamicResource CloseIcon}"
                              Width="12" Height="12" />
                </Button>
            </Grid>
        </Border>
    </Border>
</Window>
