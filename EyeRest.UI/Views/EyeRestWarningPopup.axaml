<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EyeRest.UI.Views.EyeRestWarningPopup">
    <Border Background="{DynamicResource MeshGradientBrush}"
            CornerRadius="20"
            ClipToBounds="True">
        <Grid>
            <!-- Glass Card centered -->
            <Border Background="{DynamicResource GlassCardBackground}"
                    BorderBrush="{DynamicResource GlassCardBorder}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="28,24"
                    Margin="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <!-- Icon Circle -->
                    <Border Width="56" Height="56"
                            CornerRadius="28"
                            Background="{DynamicResource EyeRestIconCircle}"
                            HorizontalAlignment="Center">
                        <PathIcon Data="{DynamicResource EyeIcon}"
                                  Width="28" Height="28"
                                  Foreground="{DynamicResource NavButtonActiveText}" />
                    </Border>

                    <!-- Title -->
                    <TextBlock Text="Eye Rest Starting Soon"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />

                    <!-- Countdown -->
                    <TextBlock Name="CountdownText"
                               Text="30 seconds"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource NavButtonActiveText}"
                               HorizontalAlignment="Center" />

                    <!-- Progress Bar (Horizontal) -->
                    <ProgressBar Name="ProgressBar"
                                 Width="200"
                                 Height="6"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="100"
                                 IsIndeterminate="False"
                                 Foreground="{DynamicResource NavButtonActiveText}"
                                 Background="{DynamicResource GlassPanelBackground}"
                                 HorizontalAlignment="Center" />

                    <!-- Hint -->
                    <TextBlock Text="Press ESC to dismiss"
                               FontSize="11"
                               Foreground="{DynamicResource ContentSubtitleText}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Close Button (top-right) -->
            <Button Name="CloseButton"
                    Classes="PopupCloseBtn"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,12,0"
                    ToolTip.Tip="Dismiss (ESC)">
                <PathIcon Data="{DynamicResource CloseIcon}"
                          Width="12" Height="12" />
            </Button>
        </Grid>
    </Border>
</UserControl>
