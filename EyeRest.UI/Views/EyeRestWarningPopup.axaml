<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EyeRest.UI.Views.EyeRestWarningPopup">
    <Grid>
        <!-- ===== FULL LAYOUT (shown initially) ===== -->
        <Border Name="FullLayout"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                IsVisible="True">
            <Border Background="{DynamicResource MeshGradientBrush}"
                    CornerRadius="20"
                    ClipToBounds="True"
                    Padding="0">
                <Border Background="{DynamicResource GlassCardBackground}"
                        BorderBrush="{DynamicResource GlassCardBorder}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="28,24">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" Spacing="12">
                            <!-- Icon Circle -->
                            <Border Width="56" Height="56"
                                    CornerRadius="28"
                                    Background="{DynamicResource EyeRestIconCircle}"
                                    HorizontalAlignment="Center">
                                <PathIcon Data="{DynamicResource EyeIcon}"
                                          Width="28" Height="28"
                                          Foreground="{DynamicResource NavButtonActiveText}" />
                            </Border>

                            <!-- Title -->
                            <TextBlock Text="Eye Rest Starting Soon"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />

                            <!-- Countdown -->
                            <TextBlock Name="CountdownText"
                                       Classes="MonoDigits"
                                       Text="30 seconds"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource NavButtonActiveText}"
                                       HorizontalAlignment="Center" />

                            <!-- Progress Bar -->
                            <ProgressBar Name="ProgressBar"
                                         Width="200"
                                         Height="6"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="100"
                                         IsIndeterminate="False"
                                         Foreground="{DynamicResource NavButtonActiveText}"
                                         Background="{DynamicResource GlassPanelBackground}"
                                         HorizontalAlignment="Center" />

                            <!-- Hint -->
                            <TextBlock Text="Press ESC to dismiss"
                                       FontSize="11"
                                       Foreground="{DynamicResource ContentSubtitleText}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Close Button -->
                        <Button Name="CloseButton"
                                Classes="PopupCloseBtn"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-4,-4,0"
                                ToolTip.Tip="Dismiss (ESC)">
                            <PathIcon Data="{DynamicResource CloseIcon}"
                                      Width="12" Height="12" />
                        </Button>
                    </Grid>
                </Border>
            </Border>
        </Border>

        <!-- ===== COMPACT LAYOUT (shown after 30s) ===== -->
        <Border Name="CompactLayout"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                IsVisible="False" Opacity="0">
            <Border Background="{DynamicResource MeshGradientBrush}"
                    CornerRadius="14"
                    ClipToBounds="True"
                    Padding="0">
                <Border Background="{DynamicResource GlassCardBackground}"
                        BorderBrush="{DynamicResource GlassCardBorder}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,10">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                        <!-- Row 0: Icon + Title + Close -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Width="24" Height="24"
                                CornerRadius="12"
                                Background="{DynamicResource EyeRestIconCircle}"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                            <PathIcon Data="{DynamicResource EyeIcon}"
                                      Width="12" Height="12"
                                      Foreground="{DynamicResource NavButtonActiveText}" />
                        </Border>

                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="Eye Rest Starting Soon"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />

                        <Button Name="CompactCloseButton"
                                Grid.Row="0" Grid.Column="2"
                                Classes="PopupCloseBtn"
                                Width="24" Height="24"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                ToolTip.Tip="Dismiss (ESC)">
                            <PathIcon Data="{DynamicResource CloseIcon}"
                                      Width="10" Height="10" />
                        </Button>

                        <!-- Row 1: Countdown + Progress Bar -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal"
                                    Margin="0,6,0,0"
                                    Spacing="10">
                            <TextBlock Name="CompactCountdownText"
                                       Classes="MonoDigits"
                                       Text="25 seconds"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavButtonActiveText}"
                                       VerticalAlignment="Center"
                                       Width="80" />

                            <ProgressBar Name="CompactProgressBar"
                                         Width="140"
                                         Height="4"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="100"
                                         IsIndeterminate="False"
                                         Foreground="{DynamicResource NavButtonActiveText}"
                                         Background="{DynamicResource GlassPanelBackground}"
                                         VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </Border>
    </Grid>
</UserControl>
