<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EyeRest.UI.ViewModels"
             xmlns:analytics="using:EyeRest.UI.Views.Analytics"
             xmlns:converters="using:EyeRest.UI.Converters"
             x:Class="EyeRest.UI.Views.AnalyticsDashboardView"
             x:DataType="vm:AnalyticsDashboardViewModel">

    <UserControl.Resources>
        <converters:EqualityConverter x:Key="EqualityConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Period pill buttons -->
        <Style Selector="Button.periodPill">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassCardBorder}" />
        </Style>
        <Style Selector="Button.periodPill.active">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="Button.periodPill /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.periodPill:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GlassCardHoverBackground}" />
        </Style>
        <Style Selector="Button.periodPill.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="Button.periodPill.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
        </Style>

        <!-- Action buttons -->
        <Style Selector="Button.actionBtn">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource GlassCardBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassCardBorder}" />
        </Style>
        <Style Selector="Button.actionBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GlassCardHoverBackground}" />
        </Style>

        <!-- Export buttons -->
        <Style Selector="Button.exportBtn">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        </Style>
        <Style Selector="Button.exportBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GlassCardHoverBackground}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Margin="28,8,28,20">

        <!-- ════════════════════════════════════════════════ -->
        <!-- Row 0: Header Bar                               -->
        <!-- ════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Margin="0,0,0,20">
            <Grid RowDefinitions="Auto,Auto">
                <!-- Title + Actions -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Analytics" FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding SelectedStartDateText, StringFormat='{}Data from {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Top">
                        <Button Classes="actionBtn" Command="{Binding RefreshDataCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource ResetIcon}" Width="12" Height="12" />
                                <TextBlock Text="Refresh" />
                            </StackPanel>
                        </Button>
                        <Button Classes="actionBtn" Command="{Binding GenerateReportCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource ChartIcon}" Width="12" Height="12" />
                                <TextBlock Text="Report" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Period + Export row -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                    <!-- Period pills -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <Button Classes="periodPill"
                                Classes.active="{Binding SelectedPeriodDays, Converter={StaticResource EqualityConverter}, ConverterParameter=7}"
                                Command="{Binding SelectPeriodCommand}" CommandParameter="7"
                                Content="7d" />
                        <Button Classes="periodPill"
                                Classes.active="{Binding SelectedPeriodDays, Converter={StaticResource EqualityConverter}, ConverterParameter=14}"
                                Command="{Binding SelectPeriodCommand}" CommandParameter="14"
                                Content="14d" />
                        <Button Classes="periodPill"
                                Classes.active="{Binding SelectedPeriodDays, Converter={StaticResource EqualityConverter}, ConverterParameter=30}"
                                Command="{Binding SelectPeriodCommand}" CommandParameter="30"
                                Content="30d" />
                        <Button Classes="periodPill"
                                Classes.active="{Binding SelectedPeriodDays, Converter={StaticResource EqualityConverter}, ConverterParameter=60}"
                                Command="{Binding SelectPeriodCommand}" CommandParameter="60"
                                Content="60d" />
                        <Button Classes="periodPill"
                                Classes.active="{Binding SelectedPeriodDays, Converter={StaticResource EqualityConverter}, ConverterParameter=90}"
                                Command="{Binding SelectPeriodCommand}" CommandParameter="90"
                                Content="90d" />
                    </StackPanel>

                    <!-- Export buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Export:" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0" />
                        <Button Classes="exportBtn" Content="JSON"
                                Command="{Binding ExportDataCommand}" CommandParameter="JSON" />
                        <Button Classes="exportBtn" Content="CSV"
                                Command="{Binding ExportDataCommand}" CommandParameter="CSV" />
                        <Button Classes="exportBtn" Content="HTML"
                                Command="{Binding ExportDataCommand}" CommandParameter="HTML" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════ -->
        <!-- Row 1: Key Performance Metrics                  -->
        <!-- ════════════════════════════════════════════════ -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,20">
            <!-- Compliance Rate -->
            <Border Classes="GlassCard" Margin="4" Padding="16">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <TextBlock Text="{Binding ComplianceRateText}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Compliance Rate" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding ComplianceRateValue}"
                                 Height="4" Margin="0,4,0,0"
                                 Foreground="{DynamicResource PrimaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Breaks Completed -->
            <Border Classes="GlassCard" Margin="4" Padding="16">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <TextBlock Text="{Binding TotalBreaksCompleted}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Breaks Completed" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding CompletedBreaksPercentageText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Breaks Skipped -->
            <Border Classes="GlassCard" Margin="4" Padding="16">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <TextBlock Text="{Binding TotalBreaksSkipped}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource ErrorBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Breaks Skipped" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding SkippedBreaksPercentageText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Total Active Time -->
            <Border Classes="GlassCard" Margin="4" Padding="16">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <TextBlock Text="{Binding TotalActiveTimeText}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Total Active Time" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding DailyAverageActiveTimeText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Health Score -->
            <Border Classes="GlassCard" Margin="4" Padding="16">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <TextBlock Text="{Binding HealthScoreText}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Eye Health Score" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <Border Classes="StatusPillBadge" HorizontalAlignment="Center"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1.5" Padding="10,3">
                        <TextBlock Text="{Binding HealthStatusText}" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ════════════════════════════════════════════════ -->
        <!-- Row 2: Tab Content                              -->
        <!-- ════════════════════════════════════════════════ -->
        <Panel Grid.Row="2">
            <TabControl Padding="0">
                <TabItem Header="Daily Overview">
                    <analytics:DailyOverviewTab DataContext="{Binding}" Margin="0,8,0,0" />
                </TabItem>
                <TabItem Header="Weekly Analysis">
                    <analytics:WeeklyAnalysisTab DataContext="{Binding}" Margin="0,8,0,0" />
                </TabItem>
                <TabItem Header="Monthly Analysis">
                    <analytics:MonthlyAnalysisTab DataContext="{Binding}" Margin="0,8,0,0" />
                </TabItem>
                <TabItem Header="Daily Details">
                    <analytics:DailyDetailsTab DataContext="{Binding}" Margin="0,8,0,0" />
                </TabItem>
                <TabItem Header="Event History">
                    <analytics:EventHistoryTab DataContext="{Binding}" Margin="0,8,0,0" />
                </TabItem>
                <TabItem Header="Data Privacy">
                    <analytics:DataPrivacyTab DataContext="{Binding}" Margin="0,8,0,0" />
                </TabItem>
            </TabControl>

            <!-- Loading Overlay -->
            <Border Background="#80000000" CornerRadius="8"
                    IsVisible="{Binding IsLoading}" ZIndex="1000">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <ProgressBar IsIndeterminate="True" Width="200"
                                 Foreground="{DynamicResource PrimaryBrush}" />
                    <TextBlock Text="Loading analytics data..."
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Panel>
    </Grid>
</UserControl>
