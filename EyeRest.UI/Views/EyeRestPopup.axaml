<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EyeRest.UI.Views.EyeRestPopup">
    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource PrimaryBrush}"
            BorderThickness="2"
            CornerRadius="20"
            Padding="30"
            BoxShadow="4 4 16 0 #66808080">
        <Grid>
            <!-- Close button inside popup, top right corner -->
            <Button Name="CloseButton"
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-15,-15,0"
                    Background="Transparent"
                    Cursor="Hand"
                    ToolTip.Tip="Skip eye rest (ESC)">
                <Button.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"
                                BorderBrush="#2196F3"
                                BorderThickness="2"
                                CornerRadius="15">
                            <TextBlock Text="&#x2715;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,10,0,0">
                <!-- Cartoon Character Placeholder (Circle with eye icon) -->
                <Panel Width="120" Height="120" Margin="0,0,0,30">
                    <Ellipse Width="120" Height="120"
                             Fill="{DynamicResource PrimaryBrush}"/>
                    <!-- Eye icon inside circle -->
                    <TextBlock Text="&#x1F441;"
                               FontSize="60"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"/>
                </Panel>

                <!-- Main Message -->
                <TextBlock Text="Time for an Eye Rest!"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Instructions -->
                <TextBlock Text="Please look at something 15ft away to rest your eyes"
                           FontSize="18"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Progress Bar -->
                <ProgressBar Name="ProgressBar"
                             Width="300"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             IsIndeterminate="False"
                             Foreground="#4CAF50"
                             Background="#E0E0E0"/>

                <!-- Time Remaining -->
                <TextBlock Name="TimeRemainingText"
                           Text="20 seconds remaining"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>

                <!-- Skip hint -->
                <TextBlock Text="Press ESC to skip"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
