<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EyeRest.UI.App"
             Name="Eye-Rest"
             RequestedThemeVariant="Light">

    <!-- macOS application-level menu (bold "Eye-Rest" in menu bar).
         Must be declared here in AXAML — setting programmatically in C# is too late
         and Avalonia will inject its default "About Avalonia" item instead. -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About Eye-Rest" Click="AboutEyeRest_OnClick" />
        </NativeMenu>
    </NativeMenu.Menu>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Resources/LightTheme.axaml" />
        <StyleInclude Source="/Resources/GlassStyles.axaml" />
    </Application.Styles>
</Application>
