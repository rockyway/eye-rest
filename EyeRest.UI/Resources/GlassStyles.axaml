    <!-- ============================================================ -->
    <!-- Nav Button Style                                              -->
    <!-- ============================================================ -->
    <Style Selector="Button.NavButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource NavButtonText}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Margin" Value="8,2" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
    </Style>
    <Style Selector="Button.NavButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NavButtonHoverBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.NavButton.active">
        <Setter Property="Background" Value="{DynamicResource NavButtonActiveBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource NavButtonActiveText}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.NavButton.active /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NavButtonActiveBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource NavButtonActiveText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.NavButton.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NavButtonActiveBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource NavButtonActiveText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <!-- ============================================================ -->
    <!-- Period Pill Button Style                                      -->
    <!-- ============================================================ -->
    <Style Selector="Button.PeriodPill">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassPanelBorder}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Height" Value="26" />
    </Style>
    <Style Selector="Button.PeriodPill:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NavButtonHoverBackground}" />
    </Style>
    <Style Selector="Button.PeriodPill.active">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.PeriodPill.active /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.PeriodPill.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <!-- ============================================================ -->
    <!-- Glass Card Style                                              -->
    <!-- ============================================================ -->
    <Style Selector="Border.GlassCard">
        <Setter Property="Background" Value="{DynamicResource GlassCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- ============================================================ -->
    <!-- Glass Panel Style                                             -->
    <!-- ============================================================ -->
    <Style Selector="Border.GlassPanel">
        <Setter Property="Background" Value="{DynamicResource GlassPanelBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassPanelBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!-- ============================================================ -->
    <!-- Gradient Action Buttons                                       -->
    <!-- ============================================================ -->
    <Style Selector="Button.GradientStart">
        <Setter Property="Background" Value="{DynamicResource StartButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Height" Value="44" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="8,3" />
    </Style>
    <Style Selector="Button.GradientStart /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource StartButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.GradientStart:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource StartButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>
    <Style Selector="Button.GradientStart:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource StartButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="Button.GradientStop">
        <Setter Property="Background" Value="{DynamicResource StopButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,2" />
    </Style>
    <Style Selector="Button.GradientStop /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource StopButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.GradientStop:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource StopButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.GradientStop:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource StopButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Button.GradientPause">
        <Setter Property="Background" Value="{DynamicResource PauseButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,2" />
    </Style>
    <Style Selector="Button.GradientPause /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PauseButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.GradientPause:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PauseButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.GradientPause:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PauseButtonGradient}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- ============================================================ -->
    <!-- Meeting Button Style                                          -->
    <!-- ============================================================ -->
    <Style Selector="Button.MeetingBtn">
        <Setter Property="Background" Value="{DynamicResource MeetingButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource MeetingButtonText}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Height" Value="38" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource MeetingButtonText}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>
    <Style Selector="Button.MeetingBtn /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource MeetingButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource MeetingButtonText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MeetingButtonText}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Button.MeetingBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ToggleCardIconBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource MeetingButtonText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MeetingButtonText}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <!-- ============================================================ -->
    <!-- Toggle Card Style                                             -->
    <!-- ============================================================ -->
    <Style Selector="Border.ToggleCard">
        <Setter Property="Background" Value="{DynamicResource GlassCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <!-- ============================================================ -->
    <!-- Slider Badge Style                                            -->
    <!-- ============================================================ -->
    <Style Selector="Border.SliderBadge">
        <Setter Property="Background" Value="{DynamicResource SliderBadgeBackground}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <!-- ============================================================ -->
    <!-- Info Card Style                                               -->
    <!-- ============================================================ -->
    <Style Selector="Border.InfoCard">
        <Setter Property="Background" Value="{DynamicResource InfoCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InfoCardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- ============================================================ -->
    <!-- Section Title / Subtitle                                      -->
    <!-- ============================================================ -->
    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="TextBlock.SectionSubtitle">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource ContentSubtitleText}" />
        <Setter Property="Margin" Value="0,0,0,24" />
    </Style>

    <!-- ============================================================ -->
    <!-- Status Card Style (legacy)                                    -->
    <!-- ============================================================ -->
    <Style Selector="Border.StatusCard">
        <Setter Property="Background" Value="{DynamicResource StatusCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource StatusCardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="8,8" />
    </Style>

    <!-- ============================================================ -->
    <!-- Status Pill Badge                                             -->
    <!-- ============================================================ -->
    <Style Selector="Border.StatusPillBadge">
        <Setter Property="Background" Value="{DynamicResource StatusCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource StatusCardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
    <Style Selector="TextBlock.StatusPillText">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <!-- ============================================================ -->
    <!-- Timer Mini Card                                               -->
    <!-- ============================================================ -->
    <Style Selector="Border.TimerMiniCard">
        <Setter Property="Background" Value="{DynamicResource GlassCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="12,14" />
    </Style>

    <!-- ============================================================ -->
    <!-- Timer Icon Circle                                             -->
    <!-- ============================================================ -->
    <Style Selector="Border.TimerIconCircle">
        <Setter Property="Background" Value="{DynamicResource ToggleCardIconBackground}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
    </Style>

    <!-- ============================================================ -->
    <!-- Timer Countdown Text                                          -->
    <!-- ============================================================ -->
    <Style Selector="TextBlock.TimerCountdown">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Consolas,Menlo,monospace" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- ============================================================ -->
    <!-- Timer Label                                                   -->
    <!-- ============================================================ -->
    <Style Selector="TextBlock.TimerLabel">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource ContentSubtitleText}" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- ============================================================ -->
    <!-- Caption Button Styles (Windows title bar)                     -->
    <!-- ============================================================ -->
    <Style Selector="Button.CaptionBtn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.CaptionBtn /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.CaptionBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NavButtonHoverBackground}" />
    </Style>
    <Style Selector="Button.CaptionCloseBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#E81123" />
    </Style>

    <!-- ============================================================ -->
    <!-- Test / Action Button in content area                          -->
    <!-- ============================================================ -->
    <Style Selector="Button.ActionBtn">
        <Setter Property="Background" Value="{DynamicResource GlassCardBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Height" Value="38" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.ActionBtn /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource GlassCardBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.ActionBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource GlassCardHoverBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Primary action button (blue tinted) -->
    <Style Selector="Button.ActionBtnPrimary">
        <Setter Property="Background" Value="{DynamicResource ToggleCardIconBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ToggleCardIconColor}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Height" Value="38" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.ActionBtnPrimary /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ToggleCardIconBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ToggleCardIconColor}" />
    </Style>
    <Style Selector="Button.ActionBtnPrimary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ToggleCardIconBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ToggleCardIconColor}" />
    </Style>

    <!-- ============================================================ -->
    <!-- Popup Close Button Style                                    -->
    <!-- ============================================================ -->
    <Style Selector="Button.PopupCloseBtn">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Background" Value="{DynamicResource GlassCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.PopupCloseBtn /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource GlassCardBackground}" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>
    <Style Selector="Button.PopupCloseBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource GlassCardHoverBackground}" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>

    <!-- Warning action button -->
    <Style Selector="Button.ActionBtnWarning">
        <Setter Property="Background" Value="#4DFB923C" />
        <Setter Property="Foreground" Value="#F97316" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Height" Value="38" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.ActionBtnWarning /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#4DFB923C" />
        <Setter Property="Foreground" Value="#F97316" />
    </Style>
    <Style Selector="Button.ActionBtnWarning:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#66FB923C" />
        <Setter Property="Foreground" Value="#F97316" />
    </Style>

</Styles>
