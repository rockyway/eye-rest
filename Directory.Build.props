<Project>
  <PropertyGroup>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <!-- NU1701: Legacy .NET Framework package compatibility -->
    <NoWarn>NU1701</NoWarn>
    <!-- Allow Windows-targeting projects to restore/build on non-Windows (macOS, Linux) -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <!-- Shared version metadata -->
    <Version>1.0.1</Version>
    <AssemblyVersion>1.0.1.0</AssemblyVersion>
    <FileVersion>1.0.1.0</FileVersion>
    <InformationalVersion>1.0.1</InformationalVersion>
    <Product>Eye Rest</Product>
    <Copyright>Copyright (c) 2026 Tam Tran</Copyright>
  </PropertyGroup>
</Project>
