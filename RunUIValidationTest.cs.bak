using System;
using System.Threading.Tasks;
using EyeRest.Models;
using EyeRest.Services;
using EyeRest.ViewModels;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Hosting;
using Microsoft.Extensions.Logging;

namespace EyeRest.Tests
{
    public class SimpleUIValidationTest
    {
        public static async Task<bool> ValidateDefaultValues()
        {
            Console.WriteLine("🧪 Testing UI Default Values...");
            
            try
            {
                // Create test host
                var host = Host.CreateDefaultBuilder()
                    .ConfigureServices(services =>
                    {
                        services.AddSingleton<IConfigurationService, ConfigurationService>();
                        services.AddSingleton<ITimerService, TimerService>();
                        services.AddSingleton<INotificationService, NotificationService>();
                        services.AddSingleton<IAudioService, AudioService>();
                        services.AddSingleton<ISystemTrayService, SystemTrayService>();
                        services.AddSingleton<IStartupManager, StartupManager>();
                        services.AddSingleton<ILoggingService, LoggingService>();
                        services.AddSingleton<IPerformanceMonitor, PerformanceMonitor>();
                        services.AddSingleton<IApplicationOrchestrator, ApplicationOrchestrator>();
                    })
                    .ConfigureLogging(logging =>
                    {
                        logging.ClearProviders();
                        logging.SetMinimumLevel(LogLevel.Warning);
                    })
                    .Build();

                await host.StartAsync();
                
                var configService = host.Services.GetRequiredService<IConfigurationService>();
                var timerService = host.Services.GetRequiredService<ITimerService>();
                var startupManager = host.Services.GetRequiredService<IStartupManager>();
                var notificationService = host.Services.GetRequiredService<INotificationService>();
                var logger = host.Services.GetRequiredService<ILogger<MainWindowViewModel>>();
                
                // Create ViewModel (simulates UI initialization)
                var viewModel = new MainWindowViewModel(configService, timerService, startupManager, notificationService, logger);
                
                // Wait for async configuration loading
                await Task.Delay(1000);
                
                // Check default values
                Console.WriteLine($"Eye Rest Interval: {viewModel.EyeRestIntervalMinutes} (expected: 20)");
                Console.WriteLine($"Eye Rest Duration: {viewModel.EyeRestDurationSeconds} (expected: 20)");
                Console.WriteLine($"Break Interval: {viewModel.BreakIntervalMinutes} (expected: 55)");
                Console.WriteLine($"Break Duration: {viewModel.BreakDurationMinutes} (expected: 5)");
                Console.WriteLine($"Audio Volume: {viewModel.AudioVolume} (expected: 50)");
                Console.WriteLine($"Eye Rest Start Sound: {viewModel.EyeRestStartSoundEnabled} (expected: True)");
                Console.WriteLine($"Break Warning: {viewModel.BreakWarningEnabled} (expected: True)");
                Console.WriteLine($"Audio Enabled: {viewModel.AudioEnabled} (expected: True)");
                
                // Validate values
                bool allCorrect = true;
                
                if (viewModel.EyeRestIntervalMinutes != 20)
                {
                    Console.WriteLine($"❌ FAIL: Eye Rest Interval is {viewModel.EyeRestIntervalMinutes}, expected 20");
                    allCorrect = false;
                }
                
                if (viewModel.EyeRestDurationSeconds != 20)
                {
                    Console.WriteLine($"❌ FAIL: Eye Rest Duration is {viewModel.EyeRestDurationSeconds}, expected 20");
                    allCorrect = false;
                }
                
                if (viewModel.BreakIntervalMinutes != 55)
                {
                    Console.WriteLine($"❌ FAIL: Break Interval is {viewModel.BreakIntervalMinutes}, expected 55");
                    allCorrect = false;
                }
                
                if (viewModel.BreakDurationMinutes != 5)
                {
                    Console.WriteLine($"❌ FAIL: Break Duration is {viewModel.BreakDurationMinutes}, expected 5");
                    allCorrect = false;
                }
                
                if (viewModel.AudioVolume != 50)
                {
                    Console.WriteLine($"❌ FAIL: Audio Volume is {viewModel.AudioVolume}, expected 50");
                    allCorrect = false;
                }
                
                if (!viewModel.EyeRestStartSoundEnabled)
                {
                    Console.WriteLine($"❌ FAIL: Eye Rest Start Sound is {viewModel.EyeRestStartSoundEnabled}, expected True");
                    allCorrect = false;
                }
                
                if (!viewModel.BreakWarningEnabled)
                {
                    Console.WriteLine($"❌ FAIL: Break Warning is {viewModel.BreakWarningEnabled}, expected True");
                    allCorrect = false;
                }
                
                if (!viewModel.AudioEnabled)
                {
                    Console.WriteLine($"❌ FAIL: Audio Enabled is {viewModel.AudioEnabled}, expected True");
                    allCorrect = false;
                }
                
                await host.StopAsync();
                host.Dispose();
                
                if (allCorrect)
                {
                    Console.WriteLine("✅ SUCCESS: All default values are correct!");
                    return true;
                }
                else
                {
                    Console.WriteLine("❌ FAILURE: Some default values are incorrect!");
                    return false;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ ERROR: {ex.Message}");
                return false;
            }
        }
        
        public static async Task Main(string[] args)
        {
            var result = await ValidateDefaultValues();
            Environment.Exit(result ? 0 : 1);
        }
    }
}