<UserControl x:Class="EyeRest.Views.BreakWarningPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource WarningBrush}"
                BorderThickness="2"
                CornerRadius="15"
                MaxWidth="400"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,50,50,0">
            <Border.Effect>
                <DropShadowEffect Color="Gray" Direction="315" ShadowDepth="8" Opacity="0.4"/>
            </Border.Effect>

            <!-- Inner Grid to allow close button overlay -->
            <Grid>
                <!-- Main content with padding -->
                <StackPanel Margin="30">
                    <!-- Warning Icon -->
                    <TextBlock Text="⏰"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <!-- Warning Message -->
                    <TextBlock Text="Break Starting Soon"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- Countdown -->
                    <TextBlock x:Name="CountdownText"
                               Text="30 seconds"
                               FontSize="16"
                               Foreground="{DynamicResource WarningBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <!-- Vertical Progress Bar with smooth animation (starts at 100, falls to 0) -->
                    <ProgressBar x:Name="ProgressBar"
                                 Width="8"
                                 Height="100"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="100"
                                 IsIndeterminate="False"
                                 Foreground="{DynamicResource WarningBrush}"
                                 Background="{DynamicResource TextSecondaryBrush}"
                                 Orientation="Vertical"
                                 HorizontalAlignment="Center">
                    </ProgressBar>

                    <!-- Skip hint -->
                    <TextBlock Text="Press ESC to dismiss"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Close button inside popup, top right corner -->
                <Button Content="✕"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Background="Transparent"
                        BorderBrush="{DynamicResource WarningBrush}"
                        BorderThickness="1"
                        Foreground="{DynamicResource WarningBrush}"
                        FontSize="12"
                        Cursor="Hand"
                        Click="CloseButton_Click"
                        ToolTip="Dismiss (ESC)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>