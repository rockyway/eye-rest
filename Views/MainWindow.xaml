<Window x:Class="EyeRest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:converters="clr-namespace:EyeRest.Converters"
        xmlns:local="clr-namespace:EyeRest.Views"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{Binding WindowTitle}"
        Height="950"
        Width="600"
        MinHeight="920"
        MaxHeight="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="20" Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto" MinHeight="120"/>
            <RowDefinition Height="Auto" MinHeight="40"/>
            <RowDefinition Height="Auto" MinHeight="50"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <!-- Exit Button on the top left -->
            <Button Content="✕ Exit" 
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="59"
                    Height="30"
                    Style="{DynamicResource ErrorButtonStyle}"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Command="{Binding ExitApplicationCommand}"
                    ToolTip="Exit application">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <!-- Dark Mode Toggle on the top right -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Margin="0,5,0,0">
                <TextBlock Text="🌙" 
                           FontSize="16" 
                           VerticalAlignment="Center" 
                           Margin="0,0,8,0"/>
                <CheckBox Content="Dark Mode" 
                          IsChecked="{Binding IsDarkMode}" 
                          VerticalAlignment="Center"
                          FontSize="12"
                          FontWeight="SemiBold"
                          ToolTip="Toggle between light and dark theme for all windows"/>
            </StackPanel>
            
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock Text="Eye-rest Settings" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource PrimaryBrush}"/>
            
            <!-- Status and Countdown -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,0" Height="55">
                <!-- Status Indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="20">
                    <Ellipse Width="12" Height="12" 
                             Fill="{Binding TimerStatusColor}" 
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TimerStatusText}" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Countdown Timers -->
                <TextBlock Text="{Binding DualCountdownText}" 
                           FontSize="13" 
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"
                           Height="20"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Tabbed Settings Content -->
        <TabControl Grid.Row="1" Margin="0,0,0,10" SelectedIndex="{Binding SelectedTabIndex}">
            
            <!-- Eye Rest Tab -->
            <TabItem Header="👁️ Eye Rest" FontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <!-- Basic Settings -->
                        <GroupBox Header="Basic Settings" Margin="0,0,0,15" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Remind every:" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EyeRestIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="10,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="minutes" VerticalAlignment="Center" Margin="5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Rest for:" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EyeRestDurationSeconds, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="10,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="seconds" VerticalAlignment="Center" Margin="5"/>

                                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" 
                                          Content="Play sound at start" 
                                          IsChecked="{Binding EyeRestStartSoundEnabled}" 
                                          Margin="0,15,0,5"/>

                                <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" 
                                          Content="Play sound at end" 
                                          IsChecked="{Binding EyeRestEndSoundEnabled}" 
                                          Margin="0,5"/>
                            </Grid>
                        </GroupBox>

                        <!-- Warning Settings -->
                        <GroupBox Header="Warning Settings" Margin="0,0,0,15" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" 
                                          Content="Show warning before eye rest" 
                                          IsChecked="{Binding EyeRestWarningEnabled}" 
                                          Margin="0,0,0,15"/>

                                <StackPanel Grid.Row="1" 
                                            Orientation="Horizontal" 
                                            IsEnabled="{Binding EyeRestWarningEnabled}"
                                            Margin="20,0,0,0">
                                    <TextBlock Text="Warning time:" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding EyeRestWarningSeconds, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="10,0"/>
                                    <TextBlock Text="seconds" VerticalAlignment="Center" Margin="5,0"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Test Controls -->
                        <GroupBox Header="Test Controls" Padding="15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="Test Eye Warning" 
                                        Command="{Binding TestWarningCommand}" 
                                        Style="{DynamicResource TestWarningButtonStyle}"
                                        Width="130"
                                        Margin="0,0,10,0"/>
                                
                                <Button Content="Test Eye Rest" 
                                        Command="{Binding TestPopupCommand}" 
                                        Style="{DynamicResource TestEyeRestButtonStyle}"
                                        Width="130"
                                        Margin="0"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Time Break Tab -->
            <TabItem Header="⏰ Time Break" FontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <!-- Basic Settings -->
                        <GroupBox Header="Basic Settings" Margin="0,0,0,15" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Work for:" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BreakIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="10,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="minutes" VerticalAlignment="Center" Margin="5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Break for:" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BreakDurationMinutes, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="10,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="minutes" VerticalAlignment="Center" Margin="5"/>
                            </Grid>
                        </GroupBox>

                        <!-- Warning Settings -->
                        <GroupBox Header="Warning Settings" Margin="0,0,0,15" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" 
                                          Content="Show warning before break" 
                                          IsChecked="{Binding BreakWarningEnabled}" 
                                          Margin="0,0,0,15"/>

                                <StackPanel Grid.Row="1" 
                                            Orientation="Horizontal" 
                                            IsEnabled="{Binding BreakWarningEnabled}"
                                            Margin="20,0,0,0">
                                    <TextBlock Text="Warning time:" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding BreakWarningSeconds, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="10,0"/>
                                    <TextBlock Text="seconds" VerticalAlignment="Center" Margin="5,0"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Overlay Settings -->
                        <GroupBox Header="Overlay Settings" Margin="0,0,0,15" Padding="15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Screen overlay opacity:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <Slider Value="{Binding OverlayOpacityPercent}" 
                                        Minimum="0" 
                                        Maximum="100" 
                                        Width="200" 
                                        TickFrequency="10" 
                                        IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding OverlayOpacityPercent}" 
                                           VerticalAlignment="Center" 
                                           Margin="15,0,5,0" 
                                           Width="30"/>
                                <TextBlock Text="%" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Break Completion Settings -->
                        <GroupBox Header="Break Completion Settings" Margin="0,0,0,15" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Configure what happens when your break timer completes:"
                                           TextWrapping="Wrap" 
                                           Margin="0,0,0,15"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                
                                <CheckBox Content="Keep break popup open until confirmed"
                                          IsChecked="{Binding RequireConfirmationAfterBreak}"
                                          Margin="0,0,0,10">
                                    <CheckBox.ToolTip>
                                        <TextBlock Text="Useful when you step away from your PC during breaks. The popup will wait for you to return and click 'Done'."
                                                   TextWrapping="Wrap"
                                                   MaxWidth="300"/>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                                
                                <CheckBox Content="Start fresh session after break confirmation"
                                          IsChecked="{Binding ResetTimersOnBreakConfirmation}"
                                          IsEnabled="{Binding RequireConfirmationAfterBreak}"
                                          Margin="20,0,0,10">
                                    <CheckBox.ToolTip>
                                        <TextBlock Text="When enabled, all timers will reset to start fresh intervals after you confirm break completion. When disabled, timers resume from where they were paused."
                                                   TextWrapping="Wrap"
                                                   MaxWidth="350"/>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                                
                                <TextBlock Text="💡 Tip: Enable both options for the best experience when taking actual breaks away from your computer."
                                           FontSize="12"
                                           FontStyle="Italic"
                                           Foreground="{DynamicResource AccentBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Test Controls -->
                        <GroupBox Header="Test Controls" Padding="15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="Test Break Warning" 
                                        Command="{Binding TestBreakWarningCommand}" 
                                        Style="{DynamicResource TestBreakWarningButtonStyle}"
                                        Width="130"
                                        Margin="0,0,10,0"/>
                                
                                <Button Content="Test Break" 
                                        Command="{Binding TestBreakCommand}" 
                                        Style="{DynamicResource TestBreakButtonStyle}"
                                        Width="130"
                                        Margin="0"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced Settings Tab -->
            <TabItem Header="🔧 Advanced" FontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <!-- Meeting Detection Settings - DISABLED: Not working reliably, needs improvement and testing in future -->
                        <GroupBox Header="Meeting Detection Settings" Margin="0,0,0,15" Padding="15" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Choose how the application detects when you're in meetings to automatically pause break timers:" 
                                           TextWrapping="Wrap" 
                                           Margin="0,0,0,15"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                                <RadioButton Content="Window-based detection (Default)" 
                                             IsChecked="{Binding IsWindowBasedDetection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             GroupName="MeetingDetection"
                                             Margin="0,0,0,10"/>
                                <TextBlock Text="   • Monitors running processes and window titles"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="20,-5,0,10"/>
                                <TextBlock Text="   • Fast and lightweight detection method"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="20,-5,0,10"/>
                                <TextBlock Text="   • Works with Teams, Zoom, Webex, and Google Meet"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="20,-5,0,15"/>

                                <RadioButton Content="Network-based detection (Advanced)" 
                                             IsChecked="{Binding IsNetworkBasedDetection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             GroupName="MeetingDetection"
                                             Margin="0,0,0,10"/>
                                <TextBlock Text="   • Monitors UDP network connections for meeting activity"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="20,-5,0,10"/>
                                <TextBlock Text="   • More accurate detection of active calls"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="20,-5,0,10"/>
                                <TextBlock Text="   • Higher CPU usage, requires elevated permissions"
                                           FontSize="12"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Margin="20,-5,0,15"/>

                                <RadioButton Content="Hybrid detection (Best of both)" 
                                             IsChecked="{Binding IsHybridDetection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             GroupName="MeetingDetection"
                                             Margin="0,0,0,10"/>
                                <TextBlock Text="   • Combines window and network-based detection"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="20,-5,0,10"/>
                                <TextBlock Text="   • Most accurate but highest resource usage"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="20,-5,0,10"/>
                                <TextBlock Text="   • Falls back gracefully if one method fails"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="20,-5,0,15"/>

                                <!-- Detection Status -->
                                <Border Background="{DynamicResource InfoBackgroundBrush}" 
                                        BorderBrush="{DynamicResource InfoBorderBrush}" 
                                        BorderThickness="1" 
                                        CornerRadius="4" 
                                        Padding="10" 
                                        Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Detection Status:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding MeetingDetectionStatus}" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Ellipse Width="8" Height="8" 
                                                     Fill="{Binding MeetingDetectionStatusColor}" 
                                                     VerticalAlignment="Center" 
                                                     Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding MeetingDetectionStatusText}" 
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Additional Settings -->
                                <CheckBox Content="Enable debug logging for meeting detection" 
                                          IsChecked="{Binding LogDetectionActivity}" 
                                          Margin="0,15,0,5"
                                          ToolTip="Log detailed information about meeting detection (may impact performance)"/>
                                
                                <CheckBox Content="Enable fallback detection methods" 
                                          IsChecked="{Binding EnableFallbackDetection}" 
                                          Margin="0,5,0,0"
                                          ToolTip="Automatically switch to backup detection methods if primary method fails"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- User Presence Settings -->
                        <GroupBox Header="Smart Pause Settings" Margin="0,0,0,15" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Automatically pause timers when you're away from your computer:" 
                                           TextWrapping="Wrap" 
                                           Margin="0,0,0,15"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                
                                <CheckBox Content="Pause when screen is locked" 
                                          IsChecked="{Binding PauseOnScreenLock}" 
                                          Margin="0,0,0,10"/>
                                
                                <CheckBox Content="Pause when monitor turns off" 
                                          IsChecked="{Binding PauseOnMonitorOff}" 
                                          Margin="0,0,0,10"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <CheckBox Content="Pause when idle for:" 
                                              IsChecked="{Binding PauseOnIdle}" 
                                              VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding IdleTimeoutMinutes, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="60" 
                                             Margin="10,0"
                                             IsEnabled="{Binding PauseOnIdle}"/>
                                    <TextBlock Text="minutes" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Audio Settings -->
                        <GroupBox Header="Audio Settings" Margin="0,0,0,15" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Configure sound notifications for eye rest and break reminders:" 
                                           TextWrapping="Wrap" 
                                           Margin="0,0,0,15"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                
                                <CheckBox Content="Enable audio notifications" 
                                          IsChecked="{Binding AudioEnabled}" 
                                          Margin="0,0,0,10"/>
                                
                                <StackPanel IsEnabled="{Binding AudioEnabled}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="Volume:" VerticalAlignment="Center" Width="100"/>
                                        <Slider Value="{Binding AudioVolume}" 
                                                Minimum="0" 
                                                Maximum="100" 
                                                Width="200" 
                                                TickFrequency="10" 
                                                IsSnapToTickEnabled="True"
                                                Margin="10,0"/>
                                        <TextBlock Text="{Binding AudioVolume}" 
                                                   VerticalAlignment="Center" 
                                                   Margin="15,0,5,0" 
                                                   Width="30"/>
                                        <TextBlock Text="%" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <!-- Custom Audio Selection -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                                        <TextBlock Text="Custom Audio:" VerticalAlignment="Center" Width="100"/>
                                        <TextBox Text="{Binding CustomSoundPath}" 
                                                 IsReadOnly="True"
                                                 Width="200" 
                                                 Margin="10,0"
                                                 VerticalAlignment="Center"
                                                 Background="{DynamicResource BackgroundLightBrush}"
                                                 ToolTip="Path to custom audio file"/>
                                        <Button Content="📁 Browse" 
                                                Command="{Binding BrowseCustomAudioCommand}" 
                                                Style="{DynamicResource InfoButtonStyle}"
                                                Width="80"
                                                Height="25"
                                                Margin="5,0"
                                                ToolTip="Select custom audio file (.wav, .mp3, .wma)"/>
                                    </StackPanel>
                                    
                                    <Button Content="🔊 Test Audio" 
                                            Command="{Binding TestCustomAudioCommand}" 
                                            Style="{DynamicResource InfoButtonStyle}"
                                            Width="120"
                                            Height="30"
                                            HorizontalAlignment="Left"
                                            Margin="0,5,0,0"
                                            ToolTip="Test the selected audio file"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Application Settings -->
                        <GroupBox Header="Application Settings" Margin="0,0,0,15" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Configure application behavior and startup options:" 
                                           TextWrapping="Wrap" 
                                           Margin="0,0,0,15"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                
                                <CheckBox Content="Start with Windows" 
                                          IsChecked="{Binding StartWithWindows}" 
                                          Margin="0,0,0,10"
                                          ToolTip="Automatically start the application when Windows starts"/>
                                
                                <CheckBox Content="Start minimized to system tray" 
                                          IsChecked="{Binding StartMinimized}" 
                                          Margin="0,0,0,10"
                                          ToolTip="Start the application minimized to the system tray"/>
                                
                                <CheckBox Content="Minimize to tray instead of closing" 
                                          IsChecked="{Binding MinimizeToTray}" 
                                          Margin="0,0,0,10"
                                          ToolTip="Minimize to system tray when closing the main window"/>
                                
                                <CheckBox Content="Show tray notifications" 
                                          IsChecked="{Binding ShowTrayNotifications}" 
                                          Margin="0,0,0,10"
                                          ToolTip="Show balloon tip notifications in the system tray"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Analytics Tab -->
            <TabItem Header="📊 Analytics" FontSize="14">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                        <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="Analytics Dashboard" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="View detailed break compliance metrics and performance analytics in a dedicated dashboard window." 
                                   FontSize="14" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,30"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   MaxWidth="400"/>
                        
                        <Button Content="📊 Open Analytics Dashboard" 
                                Command="{Binding ShowAnalyticsCommand}" 
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Width="220"
                                Height="50"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                ToolTip="Open the analytics dashboard in a larger, dedicated window"/>
                        
                        <CheckBox Content="Auto-open dashboard when clicking Analytics tab" 
                                  IsChecked="{Binding AutoOpenDashboard}" 
                                  HorizontalAlignment="Center"
                                  Margin="0,20,0,0"
                                  FontSize="14"
                                  ToolTip="Automatically open the Analytics Dashboard whenever you click on the Analytics tab"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Timer Controls - Organized in 3 Lines -->
        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,15,0,10">
            
            <!-- Line 1: Primary Controls -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Button Content="Start Timers" 
                        Command="{Binding StartTimersCommand}" 
                        Style="{DynamicResource AccentButtonStyle}"
                        Width="130"
                        Height="35"
                        Margin="8,0"/>
                
                <Button Content="Stop Timers" 
                        Command="{Binding StopTimersCommand}" 
                        Style="{DynamicResource ErrorButtonStyle}"
                        Width="130"
                        Height="35"
                        Margin="8,0"/>
            </StackPanel>
            
            <!-- Line 2: Pause/Resume Controls -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Button Content="⏸️ Pause" 
                        Command="{Binding PauseTimersCommand}" 
                        Style="{DynamicResource WarningButtonStyle}"
                        Width="130"
                        Height="35"
                        Margin="8,0"
                        IsEnabled="{Binding CanPauseTimers}"
                        ToolTip="Pause timers manually (can be resumed anytime)"/>
                
                <Button Content="▶️ Resume" 
                        Command="{Binding ResumeTimersCommand}" 
                        Style="{DynamicResource SuccessButtonStyle}"
                        Width="130"
                        Height="35"
                        Margin="8,0"
                        IsEnabled="{Binding CanResumeTimers}"
                        ToolTip="Resume paused timers"/>
            </StackPanel>
            
            <!-- Line 3: Meeting Control -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="🎥 Meeting (30m)" 
                        Command="{Binding PauseForMeetingCommand}" 
                        Style="{DynamicResource InfoButtonStyle}"
                        Width="160"
                        Height="35"
                        Margin="8,0"
                        IsEnabled="{Binding CanPauseMeeting}"
                        ToolTip="Pause timers for 30 minutes for meetings (auto-resumes)"/>
            </StackPanel>
            
        </StackPanel>

        <!-- Error Message -->
        <StackPanel Grid.Row="3" 
                    Orientation="Vertical" 
                    HorizontalAlignment="Center" 
                    Margin="0,5,0,5"
                    Visibility="{Binding HasValidationErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{DynamicResource ErrorBorderStyle}"
                    MaxWidth="600">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠️" 
                               FontSize="16" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Style="{DynamicResource ErrorTextStyle}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
            <Button Content="Restore Defaults" 
                    Command="{Binding RestoreDefaultsCommand}" 
                    Style="{DynamicResource WarningButtonStyle}"
                    Width="120"
                    Height="35"
                    Margin="10,0"/>
        </StackPanel>

    </Grid>
</Window>