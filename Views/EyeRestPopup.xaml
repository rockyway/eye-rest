<UserControl x:Class="EyeRest.Views.EyeRestPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Background="{DynamicResource SurfaceBrush}" 
                BorderBrush="{DynamicResource PrimaryBrush}"
                BorderThickness="2"
                CornerRadius="20" 
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Cartoon Character Placeholder -->
            <Ellipse Width="120" Height="120" 
                     Fill="{DynamicResource PrimaryBrush}" 
                     Margin="0,0,0,30">
                <Ellipse.Effect>
                    <DropShadowEffect Color="Gray" Direction="315" ShadowDepth="5" Opacity="0.3"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Eye icon inside circle -->
            <TextBlock Text="👁" 
                       FontSize="60" 
                       HorizontalAlignment="Center"
                       Margin="0,-100,0,70"
                       Foreground="White"/>
            
            <!-- Main Message -->
            <TextBlock Text="Time for an Eye Rest!" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            
            <!-- Instructions -->
            <TextBlock Text="Please look at something 15ft away to rest your eyes" 
                       FontSize="18" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,30"/>
            
            <!-- Progress Bar with smooth animation -->
            <ProgressBar x:Name="ProgressBar" 
                         Width="300" 
                         Height="8" 
                         Minimum="0" 
                         Maximum="100" 
                         Value="0"
                         IsIndeterminate="False"
                         Foreground="#4CAF50"
                         Background="#E0E0E0">
                <!-- Add subtle pulse animation -->
                <ProgressBar.Triggers>
                    <EventTrigger RoutedEvent="ProgressBar.ValueChanged">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                               From="0.7" To="1.0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </ProgressBar.Triggers>
            </ProgressBar>
            
            <!-- Time Remaining -->
            <TextBlock x:Name="TimeRemainingText"
                       Text="20 seconds remaining"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>

            <!-- Skip hint -->
            <TextBlock Text="Press ESC to skip"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
        
        <!-- Close button -->
        <Button Content="✕" 
                Width="30" 
                Height="30"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Background="Transparent"
                BorderBrush="#2196F3"
                BorderThickness="2"
                Foreground="#2196F3"
                FontSize="16"
                FontWeight="Bold"
                Cursor="Hand"
                Click="CloseButton_Click"
                ToolTip="Skip eye rest (ESC)">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="15">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>