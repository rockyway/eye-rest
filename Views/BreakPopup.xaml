<UserControl x:Class="EyeRest.Views.BreakPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource SurfaceBrush}" 
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="2"
            CornerRadius="8"
            Padding="30"
            MaxWidth="900"
            MaxHeight="750">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Enhanced Timer Display with Minutes and Seconds around Eye Icon -->
            <Grid Margin="0,0,0,30" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Minutes Display (Left) -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="MinutesDisplay" 
                               Text="5" 
                               FontSize="120" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="minutes" 
                               FontSize="16" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,-10,0,0"/>
                </StackPanel>
                
                <!-- Break Icon (Center) -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Ellipse Width="100" Height="100" 
                             Fill="{DynamicResource AccentBrush}" 
                             Margin="20,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="Gray" Direction="315" ShadowDepth="8" Opacity="0.4"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <!-- Break icon inside circle -->
                    <TextBlock Text="👁️" 
                               FontSize="50" 
                               HorizontalAlignment="Center"
                               Margin="0,-80,0,0"
                               Foreground="White"/>
                </StackPanel>
                
                <!-- Seconds Display (Right) -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock x:Name="SecondsDisplay" 
                               Text="00" 
                               FontSize="120" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="seconds" 
                               FontSize="16" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,-10,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Main Message -->
            <TextBlock Text="Time for a Break!" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- Instructions -->
            <TextBlock Text="Stand up, stretch, and move around to stay healthy" 
                       FontSize="16" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- Enhanced Progress Bar - Thicker and Full Width -->
            <ProgressBar x:Name="ProgressBar" 
                         Width="640" 
                         Height="36" 
                         Minimum="0" 
                         Maximum="100" 
                         Value="0"
                         IsIndeterminate="False"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource BackgroundBrush}"
                         Margin="0,20,0,20"
                         BorderThickness="0">
                <!-- Add subtle glow effect during progress -->
                <ProgressBar.Effect>
                    <DropShadowEffect x:Name="ProgressGlow"
                                      Color="#4CAF50" 
                                      Direction="0" 
                                      ShadowDepth="0" 
                                      BlurRadius="0"
                                      Opacity="0"/>
                </ProgressBar.Effect>
                <ProgressBar.Triggers>
                    <!-- Animate glow when progress is active -->
                    <EventTrigger RoutedEvent="ProgressBar.ValueChanged">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ProgressGlow"
                                               Storyboard.TargetProperty="BlurRadius"
                                               From="0" To="8" Duration="0:0:0.3"
                                               AutoReverse="True"/>
                                <DoubleAnimation Storyboard.TargetName="ProgressGlow"
                                               Storyboard.TargetProperty="Opacity"
                                               From="0" To="0.4" Duration="0:0:0.3"
                                               AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </ProgressBar.Triggers>
            </ProgressBar>

            <!-- Time Remaining -->
            <TextBlock x:Name="TimeRemainingText" 
                       Text="5 minutes remaining" 
                       FontSize="16" 
                       Foreground="#666666"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- Stretching Resources -->
            <TextBlock Text="Stretching Resources:" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="#2E7D32"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15">
                <Button x:Name="StretchingResource1" 
                        Content="Deskercise Guide" 
                        Padding="12,6"
                        Margin="3"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        Click="StretchingResource_Click"
                        Tag="https://www.healthline.com/health/deskercise"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8">
                <Button x:Name="DelayOneMinuteButton" 
                        Content="Delay 1 Minute" 
                        Padding="15,8"
                        Margin="8"
                        Background="#FF9800"
                        Foreground="White"
                        BorderThickness="0"
                        Click="DelayOneMinute_Click"/>

                <Button x:Name="DelayFiveMinutesButton" 
                        Content="Delay 5 Minutes" 
                        Padding="15,8"
                        Margin="8"
                        Background="#FF9800"
                        Foreground="White"
                        BorderThickness="0"
                        Click="DelayFiveMinutes_Click"/>

                <Button x:Name="SkipButton" 
                        Content="Skip Break" 
                        Padding="15,8"
                        Margin="8"
                        Background="#F44336"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Skip_Click"/>
            </StackPanel>

            <!-- Confirmation Button (Hidden by default, shown when break completes) -->
            <Button x:Name="ConfirmationButton" 
                    Content="Done - Start Fresh Session" 
                    Padding="20,12"
                    Margin="0,15,0,0"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="16"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    Click="ConfirmCompletion_Click">
                <Button.Effect>
                    <DropShadowEffect Color="Green" Direction="315" ShadowDepth="4" Opacity="0.3"/>
                </Button.Effect>
            </Button>

            <!-- Return instruction (Hidden by default, shown when waiting for confirmation) -->
            <TextBlock x:Name="ReturnInstructionText" 
                       Text="Click 'Done' when you return to start a fresh session"
                       FontSize="14" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,10,0,0"
                       Visibility="Collapsed"/>

            <!-- Click hint -->
            <TextBlock Text="Click anywhere to close" 
                       FontSize="12" 
                       Foreground="#888888"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </StackPanel>
    </Border>
</UserControl>